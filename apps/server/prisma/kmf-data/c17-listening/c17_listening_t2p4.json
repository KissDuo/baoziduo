": "", "content_zh": "", "parent": "0", "option": "0", "order_index": "2", "seq": "4", "q_cate": "0", "q_cate_sec": "0", "status": "0", "project": "4", "permission": "0", "correct_answer": "0", "is_agree": "0", "business_type": "0", "logic_type": "0", "subjects": null, "business_id": "0", "difficulty_level": "0", "suggested_duration_sec": "0", "input_method": "1", "is_private": "0", "encrypt_id": "626osj", "subject_cn": "LISTENING", "subject_zh": "听力", "projectname": "ielts", "html_content": "", "type_cn": "听力祖题目"}}, "answer": [], "option": [], "source": [{"id": "811", "content": "C17", "project": "4", "status": "0", "group_id": "37", "alias_content": "", "sort": "99", "is_hit": "0", "is_new_exam": "0", "hit_month": "0", "qtos_id": "80440", "seq": "0", "set": "0"}], "corpus": [], "audio": [{"id": "18297", "name": "1f152c24ec8bd8c2b7aa18e74d302117.mp3", "url": "https://img.kmf.com/ielts/listening/audio/1f152c24ec8bd8c2b7aa18e74d302117.mp3", "created_at": "2023-11-14 09:40:45", "updated_at": "2025-02-25 14:49:21", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "0", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "1f152c24ec8bd8c2b7aa18e74d302117", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/1f152c24ec8bd8c2b7aa18e74d302117.mp3", "picPath": "https://img.kmf.com/ielts/listening-img/0.jpg", "html_content": "", "section_type": "0"}, {"id": "18296", "name": "a8a494ebc4f6590f4611c6793e1db4d3.mp3", "url": "https://img.kmf.com/ielts/listening/audio/a8a494ebc4f6590f4611c6793e1db4d3.mp3", "created_at": "2023-11-14 09:40:45", "updated_at": "2025-02-25 14:49:21", "passport_id": "0", "audio_time": "278.00", "audio_pic": "", "status": "0", "content": "", "type": "1", "content_zh": "", "audio_time_human": "04:38.00", "parentPath": "", "title": "a8a494ebc4f6590f4611c6793e1db4d3", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/a8a494ebc4f6590f4611c6793e1db4d3.mp3", "picPath": "", "html_content": "", "section_type": "0"}, {"id": "18298", "name": "421cbcf4be084249f9fcb44452bbc074.mp3", "url": "https://img.kmf.com/ielts/listening/audio/421cbcf4be084249f9fcb44452bbc074.mp3", "created_at": "2023-11-14 09:40:45", "updated_at": "2025-02-25 14:49:21", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "2", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "421cbcf4be084249f9fcb44452bbc074", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/421cbcf4be084249f9fcb44452bbc074.mp3", "picPath": "", "html_content": "", "section_type": "0"}], "lyric": {"18296": {"id": "110599", "content": "", "content_zh": "", "words_num": "0", "level": "0", "parent": "0", "seq": "0", "start_time": "", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "278.00", "audio_path": "", "listen_num": "0", "listen_people": "0", "start_time_sec": "", "section": [{"id": "110600", "content": "", "content_zh": "", "words_num": "866", "level": "1", "parent": "110599", "seq": "1", "start_time": "00:00.60", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "177.28", "audio_path": "/qmmp3/18296/110600_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110601", "content": "Right, everyone, let’s make a start.", "content_zh": "好了，各位，我们开始吧。", "words_num": "6", "level": "2", "parent": "110600", "seq": "1", "start_time": "00:00.60", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "3.40", "audio_path": "/qmmp3/18296/110601_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "0.60"}, {"id": "110602", "content": "Over the past few sessions, we’ve been considering the reasons why some world languages are in decline, and today I’m going to introduce another factor that affects languages, and the speakers of those languages, and that’s technology and, in particular, digital technology.", "content_zh": "在过去的几次课程中，我们一直在考虑一些世界语言衰落的原因，今天我要介绍另一个影响语言和使用这些语言的人的因素，那就是技术，特别是数字技术。", "words_num": "42", "level": "2", "parent": "110600", "seq": "2", "start_time": "00:04.00", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "18.16", "audio_path": "/qmmp3/18296/110602_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "4.00"}, {"id": "110603", "content": "In order to illustrate its effect, I’m going to focus on the Icelandic language, which is spoken by around 321,000 people, most of whom live in Iceland – an island in the North Atlantic Ocean.", "content_zh": "为了说明它的影响，我将重点介绍冰岛语，大约有32.1万人说冰岛语，其中大多数人生活在北大西洋的一个岛屿——冰岛", "words_num": "35", "level": "2", "parent": "110600", "seq": "3", "start_time": "00:22.16", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "15.08", "audio_path": "/qmmp3/18296/110603_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "22.16"}, {"id": "110604", "content": "The problem for this language is not the number of speakers – even though this number is small.", "content_zh": "这种语言的问题不在于说这种语言的人的数量——尽管这个数字很小。", "words_num": "18", "level": "2", "parent": "110600", "seq": "4", "start_time": "00:37.24", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.60", "audio_path": "/qmmp3/18296/110604_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "37.24"}, {"id": "110605", "content": "Nor is it about losing words to other languages, such as English.", "content_zh": "也不是因为其词汇被英语等其他语言替代。", "words_num": "12", "level": "2", "parent": "110600", "seq": "5", "start_time": "00:42.84", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.56", "audio_path": "/qmmp3/18296/110605_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "42.84"}, {"id": "110606", "content": "In fact, the vocabulary of Icelandic is continually increasing because when speakers need a new word for something, they tend to create one, rather than borrowing from another language.", "content_zh": "事实上，冰岛语的词汇量在不断增加，因为当说话者需要一个新词来表达某事时，他们往往会创造一个新词，而不是从另一种语言中借用。", "words_num": "29", "level": "2", "parent": "110600", "seq": "6", "start_time": "00:47.40", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "12.60", "audio_path": "/qmmp3/18296/110606_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "47.40"}, {"id": "110607", "content": "All this makes Icelandic quite a special language – it’s changed very little in the past millennium, yet it can handle twenty-first-century concepts related to the use of computers and digital technology.", "content_zh": "所有这些都使冰岛语成为一门特殊的语言——在过去的千年里，冰岛语几乎没有什么变化，但它却能处理与计算机和数字技术使用有关的21世纪的概念。", "words_num": "32", "level": "2", "parent": "110600", "seq": "7", "start_time": "01:00.00", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "13.04", "audio_path": "/qmmp3/18296/110607_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "60.00"}, {"id": "110608", "content": "Take, for example, the word for web browser … this is vafri in Icelandic, which comes from the verb ‘to wander’.", "content_zh": "例如，网页浏览器这个词在冰岛语中是vafri，来自动词“徘徊”。", "words_num": "21", "level": "2", "parent": "110600", "seq": "8", "start_time": "01:13.04", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.56", "audio_path": "/qmmp3/18296/110608_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "73.04"}, {"id": "110609", "content": "I can’t think of a more appropriate term because that’s exactly what you do mentally when you browse the internet.", "content_zh": "我想不出一个更合适的词，因为这正是你浏览互联网时的心理活动。", "words_num": "20", "level": "2", "parent": "110600", "seq": "9", "start_time": "01:21.60", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.20", "audio_path": "/qmmp3/18296/110609_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "81.60"}, {"id": "110610", "content": "Then there’s an Icelandic word for podcast – which is too hard to pronounce! And so on.", "content_zh": "冰岛语中有一个词是播客的意思，这个词很难发音!如此种种。", "words_num": "17", "level": "2", "parent": "110600", "seq": "10", "start_time": "01:27.80", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.88", "audio_path": "/qmmp3/18296/110610_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "87.80"}, {"id": "110611", "content": "Icelandic, then, is alive and growing, but – and it’s a big but – young Icelanders spend a great deal of time in the digital world and this world is predominantly English.", "content_zh": "因此，冰岛语其实是有生命力的，并且在不断发展。 但是，不容忽视的是，冰岛的年轻人会花大量时间沉浸于数字世界，而在这个世界中，英语才是主流语言。", "words_num": "32", "level": "2", "parent": "110600", "seq": "11", "start_time": "01:34.68", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "11.28", "audio_path": "/qmmp3/18296/110611_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "94.68"}, {"id": "110612", "content": "Think about smartphones.", "content_zh": "想想智能手机。", "words_num": "3", "level": "2", "parent": "110600", "seq": "12", "start_time": "01:45.96", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "2.28", "audio_path": "/qmmp3/18296/110612_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "105.96"}, {"id": "110613", "content": "They didn’t even exist until comparatively recently, but today young people use them all the time to read books, watch TV or films, play games, listen to music, and so on.", "content_zh": "直到最近才被发明出来，但今天的年轻人一直在使用它们来读书，看电视或电影，玩游戏，听音乐，等等。", "words_num": "31", "level": "2", "parent": "110600", "seq": "13", "start_time": "01:48.24", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "12.84", "audio_path": "/qmmp3/18296/110613_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "108.24"}, {"id": "110614", "content": "Obviously, this is a good thing in many respects because it promotes their bilingual skills, but the extent of the influence of English in the virtual world is staggering and it’s all happening really fast.", "content_zh": "显然，这在很多方面都是一件好事，因为这可以提升他们的双语技能，但英语在虚拟世界中的影响力是惊人的，而且发展速度非常快。", "words_num": "35", "level": "2", "parent": "110600", "seq": "14", "start_time": "02:01.08", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "13.40", "audio_path": "/qmmp3/18296/110614_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "121.08"}, {"id": "110615", "content": "For their parents and grandparents, the change is less concerning because they already have their native-speaker skills in Icelandic.", "content_zh": "对他们的父母和祖父母来说，这种变化不太令人担忧，因为他们已经掌握了以冰岛语为母语的技能。", "words_num": "19", "level": "2", "parent": "110600", "seq": "15", "start_time": "02:14.48", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.28", "audio_path": "/qmmp3/18296/110615_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "134.48"}, {"id": "110616", "content": "But for young speakers – well, the outcome is a little troubling.", "content_zh": "但是对于年轻人来说——嗯……这结果有些令人担忧。", "words_num": "12", "level": "2", "parent": "110600", "seq": "16", "start_time": "02:21.76", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.24", "audio_path": "/qmmp3/18296/110616_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "141.76"}, {"id": "110617", "content": "For example, teachers have found that playground conversations in Icelandic secondary schools can be conducted entirely in English, while teachers of much younger children have reported situations where their classes find it easier to say what is in a picture using English, rather than Icelandic.", "content_zh": "比如教师们发现，在冰岛的中学操场上，学生们可以完全用英语进行交流。而教授低龄儿童的老师则表示，相比于使用冰岛语，班里的孩子们觉得用英文描述图片的内容更容易。", "words_num": "45", "level": "2", "parent": "110600", "seq": "17", "start_time": "02:27.00", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "18.12", "audio_path": "/qmmp3/18296/110617_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "147.00"}, {"id": "110618", "content": "The very real and worrying consequence of all this is that the young generation in Iceland is at risk of losing its mother tongue.", "content_zh": "所有这一切的真实而令人担忧的后果是，冰岛的年轻一代面临着失去母语的风险。", "words_num": "24", "level": "2", "parent": "110600", "seq": "18", "start_time": "02:45.12", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "12.76", "audio_path": "/qmmp3/18296/110618_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "165.12"}], "start_time_sec": "0.60"}, {"id": "110619", "content": "", "content_zh": "", "words_num": "518", "level": "1", "parent": "110599", "seq": "2", "start_time": "02:57.88", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "101.00", "audio_path": "/qmmp3/18296/110619_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110620", "content": "Of course, this is happening to other European languages too, but while internet companies might be willing to offer, say, French options in their systems, it’s much harder for them to justify the expense of doing the same for a language that has a population the size of a French town, such as Nice.", "content_zh": "当然，其他欧洲语言也面临这种情况。尽管互联网公司可能会在他们开发的系统中提供法语选项，但对于使用者只有法国尼斯城人口那么少的小语种，公司会认为没必要花同样的钱将它（和法语一样）加入到系统当中。", "words_num": "54", "level": "2", "parent": "110619", "seq": "1", "start_time": "02:57.88", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "18.92", "audio_path": "/qmmp3/18296/110620_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "177.88"}, {"id": "110621", "content": "The other drawback of Icelandic is the grammar, which is significantly more complex than in most languages.", "content_zh": "冰岛语的另一个缺点是语法，它比大多数语言要复杂得多。", "words_num": "17", "level": "2", "parent": "110619", "seq": "2", "start_time": "03:16.80", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.20", "audio_path": "/qmmp3/18296/110621_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "196.80"}, {"id": "110622", "content": "At the moment, the tech giants are simply not interested in tackling this.", "content_zh": "目前，科技巨头对解决这个问题根本不感兴趣。", "words_num": "13", "level": "2", "parent": "110619", "seq": "3", "start_time": "03:24.00", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.12", "audio_path": "/qmmp3/18296/110622_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "204.00"}, {"id": "110623", "content": "So, what is the Icelandic government doing about this?", "content_zh": "那么，冰岛政府在做什么呢?", "words_num": "9", "level": "2", "parent": "110619", "seq": "4", "start_time": "03:29.12", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.24", "audio_path": "/qmmp3/18296/110623_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "209.12"}, {"id": "110624", "content": "Well, large sums of money are being allocated to a language technology fund that it is hoped will lead to the development of Icelandic sourced apps and other social media and digital systems, but clearly this is going to be an uphill struggle.", "content_zh": "嗯，他们投资了一大笔钱成立了一个语言技术基金，希望它能引导以冰岛语为源的应用程序和其他社交媒体和数字系统的发展，但显然这将是一场艰苦的斗争。", "words_num": "43", "level": "2", "parent": "110619", "seq": "5", "start_time": "03:33.36", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "15.44", "audio_path": "/qmmp3/18296/110624_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "213.36"}, {"id": "110625", "content": "On the positive side, they know that Icelandic is still the official language of education and government.", "content_zh": "积极的一面是，他们知道冰岛语仍然是教育和政府的官方语言。", "words_num": "17", "level": "2", "parent": "110619", "seq": "6", "start_time": "03:48.80", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.64", "audio_path": "/qmmp3/18296/110625_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "228.80"}, {"id": "110626", "content": "It has survived for well over a thousand years and the experts predict that its future in this nation state is sound and will continue to be so.", "content_zh": "它已经存在了一千多年，专家预测，它在这个国家的地位依然稳固，并将继续如此。", "words_num": "28", "level": "2", "parent": "110619", "seq": "7", "start_time": "03:55.44", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:39", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.00", "audio_path": "/qmmp3/18296/110626_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "235.44"}, {"id": "110627", "content": "However, there’s no doubt that it’s becoming an inevitable second choice in young people’s lives.", "content_zh": "然而，毫无疑问，它正不可避免地成为年轻人生活中的第二选择。", "words_num": "15", "level": "2", "parent": "110619", "seq": "8", "start_time": "04:05.44", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.64", "audio_path": "/qmmp3/18296/110627_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "245.44"}, {"id": "110628", "content": "This raises important questions.", "content_zh": "这引出了一些重要的问题。", "words_num": "4", "level": "2", "parent": "110619", "seq": "9", "start_time": "04:12.08", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "2.88", "audio_path": "/qmmp3/18296/110628_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "252.08"}, {"id": "110629", "content": "When you consider how much of the past is tied up in a language, will young Icelanders lose their sense of their own identity?", "content_zh": "一种语言与（一个地方的）传统和历史有着密切联系。考虑到这一点，冰岛的年轻人会不会（因为失去母语能力而）失去他们自身的认同感？", "words_num": "24", "level": "2", "parent": "110619", "seq": "10", "start_time": "04:14.96", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.72", "audio_path": "/qmmp3/18296/110629_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "254.96"}, {"id": "110630", "content": "Another issue that concerns the government of Iceland is this.", "content_zh": "另一个与冰岛政府有关的问题是。", "words_num": "10", "level": "2", "parent": "110619", "seq": "11", "start_time": "04:22.68", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "3.84", "audio_path": "/qmmp3/18296/110630_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "262.68"}, {"id": "110631", "content": "If children are learning two languages through different routes, neither of which they are fully fluent in, will they be able to express themselves properly?", "content_zh": "如果孩子通过不同的途径学习两种语言，其中任何一种他们都不能完全流利掌握，他们能正确地表达自己吗?", "words_num": "25", "level": "2", "parent": "110619", "seq": "12", "start_time": "04:26.52", "created_at": "2024-11-20 13:52:30", "updated_at": "2025-02-25 14:49:40", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "11.48", "audio_path": "/qmmp3/18296/110631_20250225144935.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "266.52"}], "start_time_sec": "177.88"}]}}}, "relative_seq": ["31", "40"]}], "sectionSheet": {"id": 325, "title": "The impact of digital technology on the Icelandic language", "category_id": 0, "type": 0, "child_num": 10, "subject": 2, "question": [{"section_id": 325, "qid": 101980, "seq": 1}], "quiz_configs": []}, "logs": [], "explains": {"101981": {"officialExplain": []}, "101982": {"officialExplain": {"id": "10775", "question_id": "101982", "audio_time": null, "explain": "<p>本题为直叙。考生需要注意熟悉英文中较大数字的表达方式，并快速做出反应。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:06:57", "updated_at": "2024-10-18 17:06:57", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101983": {"officialExplain": {"id": "10776", "question_id": "101983", "audio_time": null, "explain": "<p>题干的<span lang=\"EN-GB\">growing</span>在原文中替换为<span lang=\"EN-GB\">increasing</span>，答案虽先于关键词出现，但句子难度不高。需要注意<span lang=\"EN-GB\">vocabulary</span>的拼写。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:07:07", "updated_at": "2024-10-18 17:07:07", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101984": {"officialExplain": {"id": "10777", "question_id": "101984", "audio_time": null, "explain": "<p>根据题干可知需要填入冰岛语中能表示<span lang=\"EN-GB\">computer-based concepts</span>的具体例子，且该例子和<span lang=\"EN-GB\">web browser</span>并列。<span lang=\"EN-GB\">computer-based concepts</span>在原文中替换为<span lang=\"EN-GB\">twenty-first-century concepts related to the use of computers and digital technology</span>。<span lang=\"EN-GB\">for example</span>之后首先引出第一个例子<span lang=\"EN-GB\">web browser</span>，较长的描述之后，由<span lang=\"EN-GB\">&nbsp;then</span>引出了第二个例子<span lang=\"EN-GB\">podcast</span>。此题对应原文跨度较大，关键词出现后需集中精力等待答案，同时要熟悉<span lang=\"EN-GB\">podcast</span>一词的意思和拼写。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:07:16", "updated_at": "2024-10-18 17:07:16", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101985": {"officialExplain": {"id": "10778", "question_id": "101985", "audio_time": null, "explain": "<p>根据该部分小标题可知需要听取<span lang=\"EN-GB\">young speakers</span>部分的内容，且填入内容为<span lang=\"EN-GB\">digital technology</span>的一个例子，可以简单预判所填入的内容。原文出现<span lang=\"EN-GB\">young Icelanders spend a great deal of time in the digital world</span>，可定位该题。之后下一句出现答案<span lang=\"EN-GB\">smartphones</span>，单词难度不高，但需要注意填入复数。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:07:23", "updated_at": "2024-10-18 17:07:23", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101986": {"officialExplain": {"id": "10779", "question_id": "101986", "audio_time": null, "explain": "<p>根据题干系动词<span lang=\"EN-GB\">become</span>和副词<span lang=\"EN-GB\">quickly</span>初步预判填入形容词。<span lang=\"EN-GB\">become…quickly</span>在原文中近义替换为<span lang=\"EN-GB\">promote</span>。考生需要熟悉<span lang=\"EN-GB\">bilingual</span>一词的意思和拼写。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:07:30", "updated_at": "2024-10-18 17:07:30", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101987": {"officialExplain": {"id": "10780", "question_id": "101987", "audio_time": null, "explain": "<p>根据题干可知需要填入学校的一个场合或者地点，并且学生在该场合<span lang=\"EN-GB\">/</span>地点的讨论只使用英语。录音中出现<span lang=\"EN-GB\">teachers</span>时即可联想到和题干词<span lang=\"EN-GB\">school</span>有关，后面紧接着说到<span lang=\"EN-GB\">playground conversation</span>，<span lang=\"EN-GB\">conversation</span>即替换题目中的<span lang=\"EN-GB\">discussion</span>。题干<span lang=\"EN-GB\">only</span>一词通过原文的<span lang=\"EN-GB\">entirely</span>体现，可确定答案为<span lang=\"EN-GB\">playground</span>，该词也符合读题时预测的“学校的地点”。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:07:39", "updated_at": "2024-10-18 17:07:39", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101988": {"officialExplain": {"id": "10781", "question_id": "101988", "audio_time": null, "explain": "<p>题干句意为“（年轻人）更擅长用英语而不是冰岛语来识别<span lang=\"EN-GB\">______</span>的内容”，需要填入单数可数名词。题干的<span lang=\"EN-GB\">better able</span>在原文中替换为<span lang=\"EN-GB\">easier</span>，紧接着出现答案<span lang=\"EN-GB\">picture</span>。题干的<span lang=\"EN-GB\">content</span>一词通过<span lang=\"EN-GB\">say</span>之后的宾语从句<span lang=\"EN-GB\">what is in a picture</span>体现。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:07:46", "updated_at": "2024-10-18 17:07:46", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101989": {"officialExplain": {"id": "10782", "question_id": "101989", "audio_time": null, "explain": "<p>由题干可知需要听取<span lang=\"EN-GB\">internet companies</span>很少使用冰岛语的其中一个原因。根据<span lang=\"EN-GB\">and</span>并列结构可知，听录音时需要留意和该题并列的另一个原因，即<span lang=\"EN-GB\">small number of speakers</span>。原文首先谈到了“人数少”这个原因，即<span lang=\"EN-GB\">has a population the size of a French town</span>，提示答案即将出现。后文用<span lang=\"EN-GB\">The other drawback…</span>引出另一个原因&nbsp;，即“语法复杂”，题干的<span lang=\"EN-GB\">complicated</span>替换了原文的<span lang=\"EN-GB\">complex</span>。考生需格外注意<span lang=\"EN-GB\">grammar</span>一词的拼写。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:07:56", "updated_at": "2024-10-18 17:07:56", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101990": {"officialExplain": {"id": "10783", "question_id": "101990", "audio_time": null, "explain": "<p>根据题干可知需要填入<span lang=\"EN-GB\">lose</span>的宾语，并且此事是政府所担忧的问题。另外需留意本题和该题上方的<span lang=\"EN-GB\">secure future</span>暗含转折关系。原文谈到<span lang=\"EN-GB\">future…is sound</span>之后出现转折词<span lang=\"EN-GB\">however</span>，随后出现<span lang=\"EN-GB\">raise important questions</span>。紧接着的疑问句提示这是政府所担心的事情。<span lang=\"EN-GB\">lose</span>原词重现，之后随即出现答案<span lang=\"EN-GB\">identity</span>。考生需要理解<span lang=\"EN-GB\">identity</span>一词的意思。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:08:04", "updated_at": "2024-10-18 17:08:04", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101991": {"officialExplain": {"id": "10784", "question_id": "101991", "audio_time": null, "explain": "<p>题干句意为“孩子对冰岛语和芬兰语都不<span lang=\"EN-GB\">______</span><span lang=\"EN-GB\">”</span>，可对内容做简单预判。题干的<span lang=\"EN-GB\">children</span>原词重现，<span lang=\"EN-GB\">not…either…or…</span>在原文中替换为<span lang=\"EN-GB\">neither of…</span>，随即出现答案<span lang=\"EN-GB\">fluent</span>。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 17:08:11", "updated_at": "2024-10-18 17:08:11", "type": "0", "video_ids": "", "teacher_id": "0"}}}, "quitUrl": "https://ielts.kmf.com/n/practice/listening/order", "superCorrectionInfo": [], "questionMap": [[{"qid": "101981", "parent_qid": "101980", "top_qid": "101980", "level": 2, "seq": 1, "sheet_seq": 1, "subject": 2}]], "restartUrl": "", "relationTask": null, "actionLogs": [], "abilityTestResult": [], "isTeacher": 0}, "_fixedPassage": {"692": "[note]\n# The impact of digital technology on the Icelandic language\n## The Icelandic language\n●   has approximately {Q1} speakers\n●   has a {Q2} that is still growing\n●   has not changed a lot over the last thousand years\n●   has its own words for computer-based concepts, such as web browser and {Q3}\n\n## Young speakers\n●   are big users of digital technology, such as {Q4}\n●   are becoming{Q5} very quickly\n●   are having discussions using only English while they are in the {Q6} at school\n●   are better able to identify the content of a {Q7}in English than Icelandic\n## Technology and internet companies\n●   write very little in Icelandic because of the small number of speakers and because of how complicated its {Q8} is\n\n## The Icelandic government\n●   has set up a fund to support the production of more digital content in the language\n●   believes that Icelandic has a secure future\n●   is worried that young Icelanders may lose their {Q9} as Icelanders\n●   is worried about the consequences of children not being {Q10} in either Icelandic or English"}}