ess_type": "0", "logic_type": "0", "subjects": null, "business_id": "0", "difficulty_level": "0", "suggested_duration_sec": "0", "input_method": "1", "is_private": "0", "encrypt_id": "826qlj", "subject_cn": "LISTENING", "subject_zh": "听力", "projectname": "ielts", "html_content": "", "type_cn": "听力祖题目"}}, "answer": [], "option": [], "source": [{"id": "811", "content": "C17", "project": "4", "status": "0", "group_id": "37", "alias_content": "", "sort": "99", "is_hit": "0", "is_new_exam": "0", "hit_month": "0", "qtos_id": "80436", "seq": "0", "set": "0"}], "corpus": [], "audio": [{"id": "18312", "name": "61ae2534cb18debd2d41e531c3648a05.mp3", "url": "https://img.kmf.com/ielts/listening/audio/61ae2534cb18debd2d41e531c3648a05.mp3", "created_at": "2023-11-14 16:38:43", "updated_at": "2025-02-25 14:52:34", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "0", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "61ae2534cb18debd2d41e531c3648a05", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/61ae2534cb18debd2d41e531c3648a05.mp3", "picPath": "https://img.kmf.com/ielts/listening-img/0.jpg", "html_content": "", "section_type": "0"}, {"id": "18311", "name": "df98993ad4dad727a13d70a87cfbed6c.mp3", "url": "https://img.kmf.com/ielts/listening/audio/df98993ad4dad727a13d70a87cfbed6c.mp3", "created_at": "2023-11-14 16:38:42", "updated_at": "2025-02-25 14:52:34", "passport_id": "0", "audio_time": "265.00", "audio_pic": "", "status": "0", "content": "", "type": "1", "content_zh": "", "audio_time_human": "04:25.00", "parentPath": "", "title": "df98993ad4dad727a13d70a87cfbed6c", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/df98993ad4dad727a13d70a87cfbed6c.mp3", "picPath": "", "html_content": "", "section_type": "0"}, {"id": "18313", "name": "9af6a337e545207b511dcda2fb00d9a7.mp3", "url": "https://img.kmf.com/ielts/listening/audio/9af6a337e545207b511dcda2fb00d9a7.mp3", "created_at": "2023-11-14 16:38:43", "updated_at": "2025-02-25 14:52:34", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "2", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "9af6a337e545207b511dcda2fb00d9a7", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/9af6a337e545207b511dcda2fb00d9a7.mp3", "picPath": "", "html_content": "", "section_type": "0"}], "lyric": {"18311": {"id": "110801", "content": "", "content_zh": "", "words_num": "0", "level": "0", "parent": "0", "seq": "0", "start_time": "", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "265.00", "audio_path": "", "listen_num": "0", "listen_people": "0", "start_time_sec": "", "section": [{"id": "110802", "content": "", "content_zh": "", "words_num": "674", "level": "1", "parent": "110801", "seq": "1", "start_time": "00:01.32", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "154.60", "audio_path": "/qmmp3/18311/110802_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110803", "content": "Jacinta: Hello, Easy Life Cleaning Services, Jacinta speaking.", "content_zh": "雅辛塔:你好，这里是易生活清洁服务公司，我是雅辛塔。", "words_num": "8", "level": "2", "parent": "110802", "seq": "1", "start_time": "00:01.32", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.08", "audio_path": "/qmmp3/18311/110803_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "1.32"}, {"id": "110804", "content": "Client: Oh hello. I’m looking for a cleaning service for my apartment - do you do domestic cleaning?", "content_zh": "客户:哦,你好。我想为我的公寓找一个清洁服务，你们做家庭清洁吗?", "words_num": "18", "level": "2", "parent": "110802", "seq": "2", "start_time": "00:05.40", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.80", "audio_path": "/qmmp3/18311/110804_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "5.40"}, {"id": "110805", "content": "Jacinta: Sure.", "content_zh": "杰西塔:当然。", "words_num": "2", "level": "2", "parent": "110802", "seq": "3", "start_time": "00:11.20", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "1.04", "audio_path": "/qmmp3/18311/110805_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "11.20"}, {"id": "110806", "content": "Client: Well, it’s just a one-bedroom flat. Do you have a basic cleaning package?", "content_zh": "客户:嗯，只是一居室。你们有基本清洁套餐吗?", "words_num": "14", "level": "2", "parent": "110802", "seq": "4", "start_time": "00:12.24", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.40", "audio_path": "/qmmp3/18311/110806_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "12.24"}, {"id": "110807", "content": "Jacinta: Yes. For a one-bedroom flat we’re probably looking at about two hours for a clean. So we\\\\\\'d do a thorough clean of all surfaces in each room, and polish them where necessary. Does your apartment have carpets?", "content_zh": "杰西塔:是的。对于一居室的公寓，我们可能需要两个小时来清洁。我们要彻底清洁每个房间的所有表面，并在必要的地方进行抛光。你的公寓有地毯吗?", "words_num": "38", "level": "2", "parent": "110802", "seq": "5", "start_time": "00:17.64", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "14.04", "audio_path": "/qmmp3/18311/110807_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "17.64"}, {"id": "110808", "content": "Client: No, I don’t have any, but the floor would need cleaning.", "content_zh": "客户:没有，但是地板需要清洁。", "words_num": "12", "level": "2", "parent": "110802", "seq": "6", "start_time": "00:31.68", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "3.68", "audio_path": "/qmmp3/18311/110808_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "31.68"}, {"id": "110809", "content": "Jacinta: Of course - we’d do that in every room. And we’d do a thorough clean of the kitchen and bathroom.", "content_zh": "雅辛塔:当然，我们在每个房间都这样做。我们会彻底打扫厨房和浴室。", "words_num": "21", "level": "2", "parent": "110802", "seq": "7", "start_time": "00:35.36", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.20", "audio_path": "/qmmp3/18311/110809_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "35.36"}, {"id": "110810", "content": "Client: OK.", "content_zh": "客户:好的。", "words_num": "2", "level": "2", "parent": "110802", "seq": "8", "start_time": "00:41.56", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "0.68", "audio_path": "/qmmp3/18311/110810_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "41.56"}, {"id": "110811", "content": "Jacinta: Then we have some additional services which you can request if you want - so for example, we can clean your oven for you every week.", "content_zh": "雅辛塔:如果你需要，我们还有一些额外的服务，比如，我们可以每周为你清洁烤箱。", "words_num": "27", "level": "2", "parent": "110802", "seq": "9", "start_time": "00:42.24", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.60", "audio_path": "/qmmp3/18311/110811_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "42.24"}, {"id": "110812", "content": "Client: Actually, I hardly ever use that, but can you do the fridge?", "content_zh": "客户:实际上，我很少用那个，但是你们会清洁冰箱吗?", "words_num": "13", "level": "2", "parent": "110802", "seq": "10", "start_time": "00:50.84", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.44", "audio_path": "/qmmp3/18311/110812_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "50.84"}, {"id": "110813", "content": "Jacinta: Sure. Would you like that done every week?", "content_zh": "杰西塔:当然。你想每周做一次吗?", "words_num": "9", "level": "2", "parent": "110802", "seq": "11", "start_time": "00:55.28", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "2.84", "audio_path": "/qmmp3/18311/110813_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "55.28"}, {"id": "110814", "content": "Client: Yes, definitely. And would ironing clothes be an additional service you can do?", "content_zh": "客户:是的,当然。你能提供熨烫衣服的额外服务吗?", "words_num": "14", "level": "2", "parent": "110802", "seq": "12", "start_time": "00:58.12", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.84", "audio_path": "/qmmp3/18311/110814_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "58.12"}, {"id": "110815", "content": "Jacinta: Yes, of course.", "content_zh": "雅辛塔:当然可以。", "words_num": "4", "level": "2", "parent": "110802", "seq": "13", "start_time": "01:03.96", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "1.28", "audio_path": "/qmmp3/18311/110815_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "63.96"}, {"id": "110816", "content": "Client: It wouldn’t be much, just my shirts for work that week.", "content_zh": "客户:不会太多，只是我那周上班穿的衬衫。", "words_num": "12", "level": "2", "parent": "110802", "seq": "14", "start_time": "01:05.24", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "3.52", "audio_path": "/qmmp3/18311/110816_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "65.24"}, {"id": "110817", "content": "Jacinta: That’s fine. And we could also clean your microwave if you want.", "content_zh": "杰西塔:没问题。如果你需要的话，我们还可以帮你清洗微波炉。", "words_num": "13", "level": "2", "parent": "110802", "seq": "15", "start_time": "01:08.76", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.24", "audio_path": "/qmmp3/18311/110817_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "68.76"}, {"id": "110818", "content": "Client: No, I wipe that out pretty regularly so there’s no need for that.", "content_zh": "客户:不，我经常擦，所以没必要擦。", "words_num": "14", "level": "2", "parent": "110802", "seq": "16", "start_time": "01:13.00", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.40", "audio_path": "/qmmp3/18311/110818_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "73.00"}, {"id": "110819", "content": "Jacinta: We also offer additional services that you might want a bit less often, say every month. So for example, if the inside of your windows need cleaning, we could do that.", "content_zh": "雅辛塔:我们还提供额外的服务，你可能想要频率少一点，比如每个月一次。例如，如果你的窗户内部需要清洁，我们可以做。", "words_num": "32", "level": "2", "parent": "110802", "seq": "17", "start_time": "01:17.40", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.92", "audio_path": "/qmmp3/18311/110819_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "77.40"}, {"id": "110820", "content": "Client: Yes, that’d be good. I’m on the fifteenth floor, so the outside gets done regularly by specialists, but the inside does get a bit grubby.", "content_zh": "客户:好的，那很好。我在15楼，所以外面经常由专业人士来打扫，但里面确实有点脏。", "words_num": "26", "level": "2", "parent": "110802", "seq": "18", "start_time": "01:28.32", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.36", "audio_path": "/qmmp3/18311/110820_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "88.32"}, {"id": "110821", "content": "Jacinta: And we could arrange for your curtains to get cleaned if necessary.", "content_zh": "雅辛塔:如果有必要，我们可以安排您的窗帘清洗。", "words_num": "13", "level": "2", "parent": "110802", "seq": "19", "start_time": "01:37.68", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "3.48", "audio_path": "/qmmp3/18311/110821_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "97.68"}, {"id": "110822", "content": "Client: No, they’re OK. But would you be able to do something about the balcony? It’s quite small and I don’t use it much, but it could do with a wash every month or so.", "content_zh": "客户:那倒不用。但你们能把清洁阳台吗? 它很小，我不经常用，但大约每个月洗一次就可以了。", "words_num": "35", "level": "2", "parent": "110802", "seq": "20", "start_time": "01:41.16", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.76", "audio_path": "/qmmp3/18311/110822_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "101.16"}, {"id": "110823", "content": "Jacinta: Yes, we can get the pressure washer onto that.", "content_zh": "雅辛塔:是的，我们可以用高压清洗机清洗。", "words_num": "10", "level": "2", "parent": "110802", "seq": "21", "start_time": "01:51.92", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "44.00", "audio_path": "/qmmp3/18311/110823_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "111.92"}], "start_time_sec": "1.32"}, {"id": "110824", "content": "", "content_zh": "", "words_num": "672", "level": "1", "parent": "110801", "seq": "2", "start_time": "02:35.92", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "110.00", "audio_path": "/qmmp3/18311/110824_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110825", "content": "Jacinta: Now if you’re interested, we do offer some other possibilities to do with general maintenance. For example, if you have a problem with water and you need a plumber in a hurry, we can put you in touch with a reliable one who can come out straightaway. And the same thing if you need an electrician.", "content_zh": "雅辛塔:如果你感兴趣的话，我们提供了一些其他的常规维护方案。例如，当你遇到用水问题，急需水管工时，我们可以帮你联系一个能立即赶来的靠谱的水管工。如果你需要一个电工，也是一样的。", "words_num": "57", "level": "2", "parent": "110824", "seq": "1", "start_time": "02:35.92", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "17.88", "audio_path": "/qmmp3/18311/110825_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "155.92"}, {"id": "110826", "content": "Client: Right. That’s good to know. I’ve only just moved here so I don’t have any of those sorts of contacts.", "content_zh": "客户:是的。很高兴知道这个。我刚搬到这里，所以我没有这类人脉。", "words_num": "21", "level": "2", "parent": "110824", "seq": "2", "start_time": "02:53.80", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.48", "audio_path": "/qmmp3/18311/110826_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "173.80"}, {"id": "110827", "content": "Jacinta: And I don’t know if this is of interest to you, but we also offer a special vacuum cleaning system which can improve the indoor air quality of your home by capturing up to 99% of all the dust in the air. So if you’re troubled by allergies, this can make a big difference.", "content_zh": "雅辛塔:我不知道您是否感兴趣，我们还提供一种特殊的真空清洁系统，它可以吸附空气中99%的灰尘，从而改善室内空气质量。所以如果你有过敏症的困扰，这可能会有很大的不同。", "words_num": "55", "level": "2", "parent": "110824", "seq": "3", "start_time": "03:01.28", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "17.08", "audio_path": "/qmmp3/18311/110827_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "181.28"}, {"id": "110828", "content": "Client: Right. In fact, I don’t have that sort of problem, but I’ll bear it in mind. Now can you tell me a bit about your cleaning staff?", "content_zh": "客户:好的。事实上，我没有那种问题，但我会记住的。现在你能跟我说说你们的清洁工吗?", "words_num": "28", "level": "2", "parent": "110824", "seq": "4", "start_time": "03:18.36", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.12", "audio_path": "/qmmp3/18311/110828_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "198.36"}, {"id": "110829", "content": "Jacinta: Of course. So all our cleaners are very carefully selected. When they apply to us, they have to undergo a security check with the police to make sure they don’t have any sort of criminal background, and, of course, they have to provide references as well. Then if we think they might be suitable for the job, we give them training for it. That lasts for two weeks so it’s very thorough, and at the end of it, they have a test.", "content_zh": "杰西塔:当然可以。我们所有的清洁工都是经过精心挑选的。当他们向我们申请时，他们必须接受警方的安全检查，以确保他们没有任何犯罪背景，当然，他们还必须提供推荐信。然后，如果我们认为他们可能适合这份工作，我们就给他们培训。培训持续两周，非常全面，结束后，他们会进行测试。", "words_num": "83", "level": "2", "parent": "110824", "seq": "5", "start_time": "03:26.48", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "25.96", "audio_path": "/qmmp3/18311/110829_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "206.48"}, {"id": "110830", "content": "If they pass that, we take them on, but we monitor them very carefully - we ask all our clients to complete a review of their performance after every visit and to email it to us. So we can pick up any problems straightaway and deal with them.", "content_zh": "如果他们通过了审核，我们就雇佣他们，但我们会非常仔细地监督他们——我们要求所有的客户在每次访问后完成业绩评估，并通过电子邮件发给我们。这样我们就能立即发现问题并加以处理。", "words_num": "48", "level": "2", "parent": "110824", "seq": "6", "start_time": "03:52.44", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "15.16", "audio_path": "/qmmp3/18311/110830_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "232.44"}, {"id": "110831", "content": "Client: OK, well that all sounds good. And will I always have the same cleaner?", "content_zh": "客户:好的，听起来不错。我会一直用同样的清洁工吗?", "words_num": "15", "level": "2", "parent": "110824", "seq": "7", "start_time": "04:07.60", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.84", "audio_path": "/qmmp3/18311/110831_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "247.60"}, {"id": "110832", "content": "Jacinta: Yes, we do our best to organise it that way, and we usually manage it.", "content_zh": "雅辛塔:是的，我们会尽最大努力去安排，我们通常会做到。", "words_num": "16", "level": "2", "parent": "110824", "seq": "8", "start_time": "04:13.44", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.88", "audio_path": "/qmmp3/18311/110832_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "253.44"}, {"id": "110833", "content": "Client: Good. That’s fine. Right, so I’d like to go ahead and …", "content_zh": "顾客:好的。这很好。好了，我想继续…", "words_num": "13", "level": "2", "parent": "110824", "seq": "9", "start_time": "04:18.32", "created_at": "2024-11-21 13:55:27", "updated_at": "2025-02-25 14:52:54", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.68", "audio_path": "/qmmp3/18311/110833_20250225145249.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "258.32"}], "start_time_sec": "155.92"}]}}}, "relative_seq": ["1", "10"]}], "sectionSheet": {"id": 359, "title": "Easy Life Cleaning Services", "category_id": 0, "type": 0, "child_num": 10, "subject": 2, "question": [{"section_id": 359, "qid": 102045, "seq": 1}], "quiz_configs": []}, "logs": [], "explains": {"102046": {"officialExplain": []}, "102047": {"officialExplain": {"id": "10820", "question_id": "102047", "audio_time": null, "explain": "<p>本题为直叙。有考生可能会写surfaces，请注意审题，surfaces在第一点中已经提及。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:39:13", "updated_at": "2024-10-21 10:39:13", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102048": {"officialExplain": {"id": "10821", "question_id": "102048", "audio_time": null, "explain": "<p>本题为直叙。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:39:20", "updated_at": "2024-10-21 10:39:20", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102049": {"officialExplain": {"id": "10822", "question_id": "102049", "audio_time": null, "explain": "<p>本题为直叙。题干中的ironing表示“熨烫”。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:39:27", "updated_at": "2024-10-21 10:39:27", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102050": {"officialExplain": {"id": "10823", "question_id": "102050", "audio_time": null, "explain": "<p>本题为直叙。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:39:37", "updated_at": "2024-10-21 10:39:37", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102051": {"officialExplain": {"id": "10824", "question_id": "102051", "audio_time": null, "explain": "<p>本题为直叙，curtains为干扰信息，注意排除。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:39:47", "updated_at": "2024-10-21 10:39:47", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102052": {"officialExplain": {"id": "10825", "question_id": "102052", "audio_time": null, "explain": "<p>本题为直叙，electrician在录音中说得比较快，也比较轻，考生需要需要对这个词很熟练，否则就算听到也不容易识别。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:39:54", "updated_at": "2024-10-21 10:39:54", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102053": {"officialExplain": {"id": "10826", "question_id": "102053", "audio_time": null, "explain": "<p>本题为直叙。题干中提到allergic，原文中提到的是allergies。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:40:03", "updated_at": "2024-10-21 10:40:03", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102054": {"officialExplain": {"id": "10827", "question_id": "102054", "audio_time": null, "explain": "<p>本题为直叙。题干中的carried out替换原文中的undergo。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:40:11", "updated_at": "2024-10-21 10:40:11", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102055": {"officialExplain": {"id": "10828", "question_id": "102055", "audio_time": null, "explain": "<p>本题为直叙。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:40:20", "updated_at": "2024-10-21 10:40:20", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102056": {"officialExplain": {"id": "10829", "question_id": "102056", "audio_time": null, "explain": "<p>本题为直叙。题干中的send替换原文中的email it to us。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-21 10:40:28", "updated_at": "2024-10-21 10:40:28", "type": "0", "video_ids": "", "teacher_id": "0"}}}, "quitUrl": "https://ielts.kmf.com/n/practice/listening/order", "superCorrectionInfo": [], "questionMap": [[{"qid": "102046", "parent_qid": "102045", "top_qid": "102045", "level": 2, "seq": 1, "sheet_seq": 1, "subject": 2}]], "restartUrl": "", "relationTask": null, "actionLogs": [], "abilityTestResult": [], "isTeacher": 0}}