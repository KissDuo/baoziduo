ed_at":"2023-11-14 16:38:43","updated_at":"2025-02-25 14:52:34","passport_id":"0","audio_time":"0","audio_pic":"","status":"0","content":"","type":"2","content_zh":"","audio_time_human":"0","parentPath":"","title":"9af6a337e545207b511dcda2fb00d9a7","formatType":"mp3","filePath":"https:\/\/img.kmf.com\/ielts\/listening\/audio\/9af6a337e545207b511dcda2fb00d9a7.mp3","picPath":"","html_content":"","section_type":"0"}],"lyric":{"18311":{"id":"110801","content":"","content_zh":"","words_num":"0","level":"0","parent":"0","seq":"0","start_time":"","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"265.00","audio_path":"","listen_num":"0","listen_people":"0","start_time_sec":"","section":[{"id":"110802","content":"","content_zh":"","words_num":"674","level":"1","parent":"110801","seq":"1","start_time":"00:01.32","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"154.60","audio_path":"\/qmmp3\/18311\/110802_20250225145249.mp3","listen_num":"0","listen_people":"0","sentence":[{"id":"110803","content":"Jacinta: Hello, Easy Life Cleaning Services, Jacinta speaking.","content_zh":"\u96c5\u8f9b\u5854:\u4f60\u597d\uff0c\u8fd9\u91cc\u662f\u6613\u751f\u6d3b\u6e05\u6d01\u670d\u52a1\u516c\u53f8\uff0c\u6211\u662f\u96c5\u8f9b\u5854\u3002","words_num":"8","level":"2","parent":"110802","seq":"1","start_time":"00:01.32","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"4.08","audio_path":"\/qmmp3\/18311\/110803_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"1.32"},{"id":"110804","content":"Client: Oh hello. I\u2019m looking for a cleaning service for my apartment - do you do domestic cleaning?","content_zh":"\u5ba2\u6237:\u54e6,\u4f60\u597d\u3002\u6211\u60f3\u4e3a\u6211\u7684\u516c\u5bd3\u627e\u4e00\u4e2a\u6e05\u6d01\u670d\u52a1\uff0c\u4f60\u4eec\u505a\u5bb6\u5ead\u6e05\u6d01\u5417?","words_num":"18","level":"2","parent":"110802","seq":"2","start_time":"00:05.40","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"5.80","audio_path":"\/qmmp3\/18311\/110804_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"5.40"},{"id":"110805","content":"Jacinta: Sure.","content_zh":"\u6770\u897f\u5854:\u5f53\u7136\u3002","words_num":"2","level":"2","parent":"110802","seq":"3","start_time":"00:11.20","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"1.04","audio_path":"\/qmmp3\/18311\/110805_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"11.20"},{"id":"110806","content":"Client: Well, it\u2019s just a one-bedroom flat. Do you have a basic cleaning package?","content_zh":"\u5ba2\u6237:\u55ef\uff0c\u53ea\u662f\u4e00\u5c45\u5ba4\u3002\u4f60\u4eec\u6709\u57fa\u672c\u6e05\u6d01\u5957\u9910\u5417?","words_num":"14","level":"2","parent":"110802","seq":"4","start_time":"00:12.24","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"5.40","audio_path":"\/qmmp3\/18311\/110806_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"12.24"},{"id":"110807","content":"Jacinta: Yes. For a one-bedroom flat we\u2019re probably looking at about two hours for a clean. So we\\\\\\'d do a thorough clean of all surfaces in each room, and polish them where necessary. Does your apartment have carpets?","content_zh":"\u6770\u897f\u5854:\u662f\u7684\u3002\u5bf9\u4e8e\u4e00\u5c45\u5ba4\u7684\u516c\u5bd3\uff0c\u6211\u4eec\u53ef\u80fd\u9700\u8981\u4e24\u4e2a\u5c0f\u65f6\u6765\u6e05\u6d01\u3002\u6211\u4eec\u8981\u5f7b\u5e95\u6e05\u6d01\u6bcf\u4e2a\u623f\u95f4\u7684\u6240\u6709\u8868\u9762\uff0c\u5e76\u5728\u5fc5\u8981\u7684\u5730\u65b9\u8fdb\u884c\u629b\u5149\u3002\u4f60\u7684\u516c\u5bd3\u6709\u5730\u6bef\u5417?","words_num":"38","level":"2","parent":"110802","seq":"5","start_time":"00:17.64","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"14.04","audio_path":"\/qmmp3\/18311\/110807_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"17.64"},{"id":"110808","content":"Client: No, I don\u2019t have any, but the floor would need cleaning.","content_zh":"\u5ba2\u6237:\u6ca1\u6709\uff0c\u4f46\u662f\u5730\u677f\u9700\u8981\u6e05\u6d01\u3002","words_num":"12","level":"2","parent":"110802","seq":"6","start_time":"00:31.68","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"3.68","audio_path":"\/qmmp3\/18311\/110808_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"31.68"},{"id":"110809","content":"Jacinta: Of course - we\u2019d do that in every room. And we\u2019d do a thorough clean of the kitchen and bathroom.","content_zh":"\u96c5\u8f9b\u5854:\u5f53\u7136\uff0c\u6211\u4eec\u5728\u6bcf\u4e2a\u623f\u95f4\u90fd\u8fd9\u6837\u505a\u3002\u6211\u4eec\u4f1a\u5f7b\u5e95\u6253\u626b\u53a8\u623f\u548c\u6d74\u5ba4\u3002","words_num":"21","level":"2","parent":"110802","seq":"7","start_time":"00:35.36","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"6.20","audio_path":"\/qmmp3\/18311\/110809_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"35.36"},{"id":"110810","content":"Client: OK.","content_zh":"\u5ba2\u6237:\u597d\u7684\u3002","words_num":"2","level":"2","parent":"110802","seq":"8","start_time":"00:41.56","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"0.68","audio_path":"\/qmmp3\/18311\/110810_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"41.56"},{"id":"110811","content":"Jacinta: Then we have some additional services which you can request if you want - so for example, we can clean your oven for you every week.","content_zh":"\u96c5\u8f9b\u5854:\u5982\u679c\u4f60\u9700\u8981\uff0c\u6211\u4eec\u8fd8\u6709\u4e00\u4e9b\u989d\u5916\u7684\u670d\u52a1\uff0c\u6bd4\u5982\uff0c\u6211\u4eec\u53ef\u4ee5\u6bcf\u5468\u4e3a\u4f60\u6e05\u6d01\u70e4\u7bb1\u3002","words_num":"27","level":"2","parent":"110802","seq":"9","start_time":"00:42.24","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"8.60","audio_path":"\/qmmp3\/18311\/110811_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"42.24"},{"id":"110812","content":"Client: Actually, I hardly ever use that, but can you do the fridge?","content_zh":"\u5ba2\u6237:\u5b9e\u9645\u4e0a\uff0c\u6211\u5f88\u5c11\u7528\u90a3\u4e2a\uff0c\u4f46\u662f\u4f60\u4eec\u4f1a\u6e05\u6d01\u51b0\u7bb1\u5417?","words_num":"13","level":"2","parent":"110802","seq":"10","start_time":"00:50.84","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"4.44","audio_path":"\/qmmp3\/18311\/110812_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"50.84"},{"id":"110813","content":"Jacinta: Sure. Would you like that done every week?","content_zh":"\u6770\u897f\u5854:\u5f53\u7136\u3002\u4f60\u60f3\u6bcf\u5468\u505a\u4e00\u6b21\u5417?","words_num":"9","level":"2","parent":"110802","seq":"11","start_time":"00:55.28","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"2.84","audio_path":"\/qmmp3\/18311\/110813_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"55.28"},{"id":"110814","content":"Client: Yes, definitely. And would ironing clothes be an additional service you can do?","content_zh":"\u5ba2\u6237:\u662f\u7684,\u5f53\u7136\u3002\u4f60\u80fd\u63d0\u4f9b\u71a8\u70eb\u8863\u670d\u7684\u989d\u5916\u670d\u52a1\u5417?","words_num":"14","level":"2","parent":"110802","seq":"12","start_time":"00:58.12","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"5.84","audio_path":"\/qmmp3\/18311\/110814_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"58.12"},{"id":"110815","content":"Jacinta: Yes, of course.","content_zh":"\u96c5\u8f9b\u5854:\u5f53\u7136\u53ef\u4ee5\u3002","words_num":"4","level":"2","parent":"110802","seq":"13","start_time":"01:03.96","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"1.28","audio_path":"\/qmmp3\/18311\/110815_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"63.96"},{"id":"110816","content":"Client: It wouldn\u2019t be much, just my shirts for work that week.","content_zh":"\u5ba2\u6237:\u4e0d\u4f1a\u592a\u591a\uff0c\u53ea\u662f\u6211\u90a3\u5468\u4e0a\u73ed\u7a7f\u7684\u886c\u886b\u3002","words_num":"12","level":"2","parent":"110802","seq":"14","start_time":"01:05.24","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"3.52","audio_path":"\/qmmp3\/18311\/110816_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"65.24"},{"id":"110817","content":"Jacinta: That\u2019s fine. And we could also clean your microwave if you want.","content_zh":"\u6770\u897f\u5854:\u6ca1\u95ee\u9898\u3002\u5982\u679c\u4f60\u9700\u8981\u7684\u8bdd\uff0c\u6211\u4eec\u8fd8\u53ef\u4ee5\u5e2e\u4f60\u6e05\u6d17\u5fae\u6ce2\u7089\u3002","words_num":"13","level":"2","parent":"110802","seq":"15","start_time":"01:08.76","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"4.24","audio_path":"\/qmmp3\/18311\/110817_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"68.76"},{"id":"110818","content":"Client: No, I wipe that out pretty regularly so there\u2019s no need for that.","content_zh":"\u5ba2\u6237:\u4e0d\uff0c\u6211\u7ecf\u5e38\u64e6\uff0c\u6240\u4ee5\u6ca1\u5fc5\u8981\u64e6\u3002","words_num":"14","level":"2","parent":"110802","seq":"16","start_time":"01:13.00","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"4.40","audio_path":"\/qmmp3\/18311\/110818_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"73.00"},{"id":"110819","content":"Jacinta: We also offer additional services that you might want a bit less often, say every month. So for example, if the inside of your windows need cleaning, we could do that.","content_zh":"\u96c5\u8f9b\u5854:\u6211\u4eec\u8fd8\u63d0\u4f9b\u989d\u5916\u7684\u670d\u52a1\uff0c\u4f60\u53ef\u80fd\u60f3\u8981\u9891\u7387\u5c11\u4e00\u70b9\uff0c\u6bd4\u5982\u6bcf\u4e2a\u6708\u4e00\u6b21\u3002\u4f8b\u5982\uff0c\u5982\u679c\u4f60\u7684\u7a97\u6237\u5185\u90e8\u9700\u8981\u6e05\u6d01\uff0c\u6211\u4eec\u53ef\u4ee5\u505a\u3002","words_num":"32","level":"2","parent":"110802","seq":"17","start_time":"01:17.40","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"10.92","audio_path":"\/qmmp3\/18311\/110819_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"77.40"},{"id":"110820","content":"Client: Yes, that\u2019d be good. I\u2019m on the fifteenth floor, so the outside gets done regularly by specialists, but the inside does get a bit grubby.","content_zh":"\u5ba2\u6237:\u597d\u7684\uff0c\u90a3\u5f88\u597d\u3002\u6211\u572815\u697c\uff0c\u6240\u4ee5\u5916\u9762\u7ecf\u5e38\u7531\u4e13\u4e1a\u4eba\u58eb\u6765\u6253\u626b\uff0c\u4f46\u91cc\u9762\u786e\u5b9e\u6709\u70b9\u810f\u3002","words_num":"26","level":"2","parent":"110802","seq":"18","start_time":"01:28.32","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"9.36","audio_path":"\/qmmp3\/18311\/110820_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"88.32"},{"id":"110821","content":"Jacinta: And we could arrange for your curtains to get cleaned if necessary.","content_zh":"\u96c5\u8f9b\u5854:\u5982\u679c\u6709\u5fc5\u8981\uff0c\u6211\u4eec\u53ef\u4ee5\u5b89\u6392\u60a8\u7684\u7a97\u5e18\u6e05\u6d17\u3002","words_num":"13","level":"2","parent":"110802","seq":"19","start_time":"01:37.68","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"3.48","audio_path":"\/qmmp3\/18311\/110821_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"97.68"},{"id":"110822","content":"Client: No, they\u2019re OK. But would you be able to do something about the balcony? It\u2019s quite small and I don\u2019t use it much, but it could do with a wash every month or so.","content_zh":"\u5ba2\u6237:\u90a3\u5012\u4e0d\u7528\u3002\u4f46\u4f60\u4eec\u80fd\u628a\u6e05\u6d01\u9633\u53f0\u5417? \u5b83\u5f88\u5c0f\uff0c\u6211\u4e0d\u7ecf\u5e38\u7528\uff0c\u4f46\u5927\u7ea6\u6bcf\u4e2a\u6708\u6d17\u4e00\u6b21\u5c31\u53ef\u4ee5\u4e86\u3002","words_num":"35","level":"2","parent":"110802","seq":"20","start_time":"01:41.16","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"10.76","audio_path":"\/qmmp3\/18311\/110822_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"101.16"},{"id":"110823","content":"Jacinta: Yes, we can get the pressure washer onto that.","content_zh":"\u96c5\u8f9b\u5854:\u662f\u7684\uff0c\u6211\u4eec\u53ef\u4ee5\u7528\u9ad8\u538b\u6e05\u6d17\u673a\u6e05\u6d17\u3002","words_num":"10","level":"2","parent":"110802","seq":"21","start_time":"01:51.92","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"44.00","audio_path":"\/qmmp3\/18311\/110823_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"111.92"}],"start_time_sec":"1.32"},{"id":"110824","content":"","content_zh":"","words_num":"672","level":"1","parent":"110801","seq":"2","start_time":"02:35.92","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"110.00","audio_path":"\/qmmp3\/18311\/110824_20250225145249.mp3","listen_num":"0","listen_people":"0","sentence":[{"id":"110825","content":"Jacinta: Now if you\u2019re interested, we do offer some other possibilities to do with general maintenance. For example, if you have a problem with water and you need a plumber in a hurry, we can put you in touch with a reliable one who can come out straightaway. And the same thing if you need an electrician.","content_zh":"\u96c5\u8f9b\u5854:\u5982\u679c\u4f60\u611f\u5174\u8da3\u7684\u8bdd\uff0c\u6211\u4eec\u63d0\u4f9b\u4e86\u4e00\u4e9b\u5176\u4ed6\u7684\u5e38\u89c4\u7ef4\u62a4\u65b9\u6848\u3002\u4f8b\u5982\uff0c\u5f53\u4f60\u9047\u5230\u7528\u6c34\u95ee\u9898\uff0c\u6025\u9700\u6c34\u7ba1\u5de5\u65f6\uff0c\u6211\u4eec\u53ef\u4ee5\u5e2e\u4f60\u8054\u7cfb\u4e00\u4e2a\u80fd\u7acb\u5373\u8d76\u6765\u7684\u9760\u8c31\u7684\u6c34\u7ba1\u5de5\u3002\u5982\u679c\u4f60\u9700\u8981\u4e00\u4e2a\u7535\u5de5\uff0c\u4e5f\u662f\u4e00\u6837\u7684\u3002","words_num":"57","level":"2","parent":"110824","seq":"1","start_time":"02:35.92","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"17.88","audio_path":"\/qmmp3\/18311\/110825_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"155.92"},{"id":"110826","content":"Client: Right. That\u2019s good to know. I\u2019ve only just moved here so I don\u2019t have any of those sorts of contacts.","content_zh":"\u5ba2\u6237:\u662f\u7684\u3002\u5f88\u9ad8\u5174\u77e5\u9053\u8fd9\u4e2a\u3002\u6211\u521a\u642c\u5230\u8fd9\u91cc\uff0c\u6240\u4ee5\u6211\u6ca1\u6709\u8fd9\u7c7b\u4eba\u8109\u3002","words_num":"21","level":"2","parent":"110824","seq":"2","start_time":"02:53.80","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"7.48","audio_path":"\/qmmp3\/18311\/110826_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"173.80"},{"id":"110827","content":"Jacinta: And I don\u2019t know if this is of interest to you, but we also offer a special vacuum cleaning system which can improve the indoor air quality of your home by capturing up to 99% of all the dust in the air. So if you\u2019re troubled by allergies, this can make a big difference.","content_zh":"\u96c5\u8f9b\u5854:\u6211\u4e0d\u77e5\u9053\u60a8\u662f\u5426\u611f\u5174\u8da3\uff0c\u6211\u4eec\u8fd8\u63d0\u4f9b\u4e00\u79cd\u7279\u6b8a\u7684\u771f\u7a7a\u6e05\u6d01\u7cfb\u7edf\uff0c\u5b83\u53ef\u4ee5\u5438\u9644\u7a7a\u6c14\u4e2d99%\u7684\u7070\u5c18\uff0c\u4ece\u800c\u6539\u5584\u5ba4\u5185\u7a7a\u6c14\u8d28\u91cf\u3002\u6240\u4ee5\u5982\u679c\u4f60\u6709\u8fc7\u654f\u75c7\u7684\u56f0\u6270\uff0c\u8fd9\u53ef\u80fd\u4f1a\u6709\u5f88\u5927\u7684\u4e0d\u540c\u3002","words_num":"55","level":"2","parent":"110824","seq":"3","start_time":"03:01.28","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"17.08","audio_path":"\/qmmp3\/18311\/110827_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"181.28"},{"id":"110828","content":"Client: Right. In fact, I don\u2019t have that sort of problem, but I\u2019ll bear it in mind. Now can you tell me a bit about your cleaning staff?","content_zh":"\u5ba2\u6237:\u597d\u7684\u3002\u4e8b\u5b9e\u4e0a\uff0c\u6211\u6ca1\u6709\u90a3\u79cd\u95ee\u9898\uff0c\u4f46\u6211\u4f1a\u8bb0\u4f4f\u7684\u3002\u73b0\u5728\u4f60\u80fd\u8ddf\u6211\u8bf4\u8bf4\u4f60\u4eec\u7684\u6e05\u6d01\u5de5\u5417?","words_num":"28","level":"2","parent":"110824","seq":"4","start_time":"03:18.36","created_at":"2024-11-21 13:55:27","updated_at":"2025-02-25 14:52:54","passport_id":"11877510","status":"0","collect_num":"0","audio_time":"8.12","audio_path":"\/qmmp3\/18311\/110828_20250225145249.mp3","listen_num":"0","listen_people":"0","start_time_sec":"198.36"},{"id":"110829","content":"Jacinta: Of course. So all our cleaners are very carefully selected. When they apply to us, they have to undergo a security check with the police to make sure they don\u2019t have any sort of criminal background, and, of course, they have to provide references as well. Then if we think they might be suitable for the job, we give them training for it. That lasts for two weeks so it\u2019s very thorough, and at the end of it, they have a test.","content_zh":"\u6770\u897f\u5854:\u5f53\u7136\u53ef\u4ee5\u3002\u6211\u4eec\u6240\u6709\u7684\u6e05\u6d01\u5de5\u90fd\u662f\u7ecf\u8fc7\u7cbe\u5fc3\u6311\u9009\u7684\u3002\u5f53\u4ed6\u4eec\u5411\u6211\u4eec\u7533\u8bf7\u65f6\uff0c\u4ed6\u4eec\u5fc5\u987b\u63a5\u53d7\u8b66\u65b9\u7684\u5b89\u5168\u68c0\u67e5\uff0c\u4ee5\u786e\u4fdd\u4ed6\u4eec\u6ca1\u6709\u4efb\u4f55\u72af\u7f6a\u80cc\u666f\uff0c\u5f53\u7136\uff0c\u4ed6\u4eec\u8fd8\u5fc5\u987b\u63d0\u4f9b\u63a8\u8350\u4fe1\u3002\u7136\u540e\uff0c\u5982\u679c\u6211\u4eec\u8ba4\u4e3a\u4ed6\u4eec\u53ef\u80fd\u9002\u5408\u8fd9\u4efd\u5de5\u4f5c\uff0c\u6211\u4eec\u5c31\u7ed9\u4ed6\u4eec\u57f9\u8bad\u3002\u57f9\u8bad\u6301\u7eed\u4e24\u5468\uff0c\u975e\u