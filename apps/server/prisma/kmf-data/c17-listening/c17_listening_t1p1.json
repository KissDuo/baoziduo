us": "0", "group_id": "37", "alias_content": "", "sort": "99", "is_hit": "0", "is_new_exam": "0", "hit_month": "0", "qtos_id": "80356", "seq": "0", "set": "0"}], "corpus": [], "audio": [{"id": "18276", "name": "cf0651ec7b78ecc1564f8533b10bcced.mp3", "url": "https://img.kmf.com/ielts/listening/audio/cf0651ec7b78ecc1564f8533b10bcced.mp3", "created_at": "2023-11-13 13:57:17", "updated_at": "2025-02-25 14:24:20", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "0", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "cf0651ec7b78ecc1564f8533b10bcced", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/cf0651ec7b78ecc1564f8533b10bcced.mp3", "picPath": "https://img.kmf.com/ielts/listening-img/0.jpg", "html_content": "", "section_type": "0"}, {"id": "18275", "name": "c75d52bb829d8c7275ff85b456dea4aa.mp3", "url": "https://img.kmf.com/ielts/listening/audio/c75d52bb829d8c7275ff85b456dea4aa.mp3", "created_at": "2023-11-13 13:57:17", "updated_at": "2025-02-25 14:24:20", "passport_id": "0", "audio_time": "287.00", "audio_pic": "", "status": "0", "content": "", "type": "1", "content_zh": "", "audio_time_human": "04:47.00", "parentPath": "", "title": "c75d52bb829d8c7275ff85b456dea4aa", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/c75d52bb829d8c7275ff85b456dea4aa.mp3", "picPath": "", "html_content": "", "section_type": "0"}, {"id": "18277", "name": "246adf18567ef5868c555eef619b36b6.mp3", "url": "https://img.kmf.com/ielts/listening/audio/246adf18567ef5868c555eef619b36b6.mp3", "created_at": "2023-11-13 13:57:17", "updated_at": "2025-02-25 14:24:20", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "2", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "246adf18567ef5868c555eef619b36b6", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/246adf18567ef5868c555eef619b36b6.mp3", "picPath": "", "html_content": "", "section_type": "0"}], "lyric": {"18275": {"id": "110321", "content": "", "content_zh": "", "words_num": "0", "level": "0", "parent": "0", "seq": "0", "start_time": "", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "287.00", "audio_path": "", "listen_num": "0", "listen_people": "0", "start_time_sec": "", "section": [{"id": "110322", "content": "", "content_zh": "", "words_num": "698", "level": "1", "parent": "110321", "seq": "1", "start_time": "00:00.88", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "160.48", "audio_path": "/qmmp3/18275/110322_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110323", "content": "Peter: Hello?", "content_zh": "彼得：你好?", "words_num": "2", "level": "2", "parent": "110322", "seq": "1", "start_time": "00:00.88", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "0.96", "audio_path": "/qmmp3/18275/110323_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "0.88"}, {"id": "110324", "content": "Jan: Oh hello. My name’s Jan. Are you the right person to talk to about the Buckworth Conservation Group?", "content_zh": "简：哦,你好。我叫简，请问你是巴克沃斯保护组织的对接人吗?", "words_num": "19", "level": "2", "parent": "110322", "seq": "2", "start_time": "00:01.84", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.88", "audio_path": "/qmmp3/18275/110324_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "1.84"}, {"id": "110325", "content": "Peter: Yes, I’m Peter. I’m the secretary.", "content_zh": "彼得：是的，我是彼得。我是秘书。", "words_num": "7", "level": "2", "parent": "110322", "seq": "3", "start_time": "00:09.72", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "2.56", "audio_path": "/qmmp3/18275/110325_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "9.72"}, {"id": "110326", "content": "Jan: Good. I’ve just moved to this area, and I’m interested in getting involved. I was in a similar group where I used to live. Could you tell me something about your activities, please?", "content_zh": "简：好的。我刚搬到这个地区，我很想参与其中。我在之前生活的地方参加过类似的组织。你能告诉我一些你们的活动吗?", "words_num": "34", "level": "2", "parent": "110322", "seq": "4", "start_time": "00:12.28", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "12.20", "audio_path": "/qmmp3/18275/110326_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "12.28"}, {"id": "110327", "content": "Peter: Of course. Well, we have a mixture of regular activities and special events. One of the regular ones is trying to keep the beach free of litter. A few of us spend a couple of hours a month on it, and it\\\\\\'s awful how much there is to clear. I wish people would be more responsible and take it home with them.", "content_zh": "彼得：当然。嗯，我们有常规活动和特殊活动。其中一项日常工作是清理海滩的垃圾。我们几个人每个月都要花几小时才能完成。要清理的垃圾很多，让人很不愉快。我希望人们能够更加负责，把垃圾带回家。", "words_num": "63", "level": "2", "parent": "110322", "seq": "5", "start_time": "00:24.48", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "18.24", "audio_path": "/qmmp3/18275/110327_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "24.48"}, {"id": "110328", "content": "Jan: I totally agree. I’d be happy to help with that. Is it OK to take dogs?", "content_zh": "简：我完全同意。我很乐意帮忙。带狗可以吗?", "words_num": "17", "level": "2", "parent": "110322", "seq": "6", "start_time": "00:42.72", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.24", "audio_path": "/qmmp3/18275/110328_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "42.72"}, {"id": "110329", "content": "Peter: I’m afraid not, as they’re banned from the beach itself. You can take them along the cliffs, though. And children are welcome.", "content_zh": "彼得： 恐怕不行，因为海滩区域本身不允许它们（狗）进入。不过你可以带它们沿着悬崖走走。", "words_num": "23", "level": "2", "parent": "110322", "seq": "7", "start_time": "00:48.96", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.28", "audio_path": "/qmmp3/18275/110329_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "48.96"}, {"id": "110330", "content": "Jan: Right.", "content_zh": "简：好的。", "words_num": "2", "level": "2", "parent": "110322", "seq": "8", "start_time": "00:56.24", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "1.20", "audio_path": "/qmmp3/18275/110330_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "56.24"}, {"id": "110331", "content": "Peter: We also manage a nature reserve, and there’s a lot to do there all year round. For example, because it’s a popular place to visit, we spend a lot of time looking after the paths and making sure they’re in good condition for walking.", "content_zh": "彼得：我们还管理一个自然保护区，全年都有很多事情可做。例如，因为这是一个受欢迎的地方，我们会花很多时间打理道路，确保它们方便行走。", "words_num": "45", "level": "2", "parent": "110322", "seq": "9", "start_time": "00:57.44", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "13.44", "audio_path": "/qmmp3/18275/110331_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "57.44"}, {"id": "110332", "content": "Jan: I could certainly help with that.", "content_zh": "简：我完全可以帮忙。", "words_num": "7", "level": "2", "parent": "110322", "seq": "10", "start_time": "01:10.88", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "2.36", "audio_path": "/qmmp3/18275/110332_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "70.88"}, {"id": "110333", "content": "Peter: Good. And we have a programme of creating new habitats there. We’ve just finished making and installing nesting boxes for birds to use, and next we’re going to work on encouraging insects – they’re important for the biodiversity of the reserve.", "content_zh": "彼得：好的。我们计划在那里创造新的栖息地。我们刚刚完成并安装了供鸟类使用的筑巢盒，接下来我们将致力于促进昆虫的繁殖——它们对保护区的生物多样性很重要。", "words_num": "42", "level": "2", "parent": "110322", "seq": "11", "start_time": "01:13.24", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "15.92", "audio_path": "/qmmp3/18275/110333_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "73.24"}, {"id": "110334", "content": "Jan: They certainly are.", "content_zh": "简：确实是。", "words_num": "4", "level": "2", "parent": "110322", "seq": "12", "start_time": "01:29.16", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "1.48", "audio_path": "/qmmp3/18275/110334_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "89.16"}, {"id": "110335", "content": "Peter: Oh, and we’re also running a project to identify the different species of butterflies that visit the reserve. You might be interested in taking part in that.", "content_zh": "彼得：哦，我们还在进行一个项目，鉴定到访保护区的不同种类的蝴蝶。你可能会有兴趣参加。", "words_num": "28", "level": "2", "parent": "110322", "seq": "13", "start_time": "01:30.64", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.40", "audio_path": "/qmmp3/18275/110335_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "90.64"}, {"id": "110336", "content": "Jan: Sure. I was involved in something similar where I used to live, counting all the species of moths. I’d enjoy that.", "content_zh": "简：当然。我在曾经生活过的地方参与了一项类似的工作，计算所有飞蛾的种类。我会乐于其中。", "words_num": "22", "level": "2", "parent": "110322", "seq": "14", "start_time": "01:40.04", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.64", "audio_path": "/qmmp3/18275/110336_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "100.04"}, {"id": "110337", "content": "Peter: Another job we’re doing at the reserve is replacing the wall on the southern side, between the parking area and our woodshed. It was badly damaged in a storm last month.", "content_zh": "彼得：我们在保护区做的另一项工作是更换南面的墙，也就是停车场和我们的木棚之间的墙。它在上个月的一场风暴中严重受损。", "words_num": "32", "level": "2", "parent": "110322", "seq": "15", "start_time": "01:48.68", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.52", "audio_path": "/qmmp3/18275/110337_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "108.68"}, {"id": "110338", "content": "Jan: OK.", "content_zh": "简：好的。", "words_num": "2", "level": "2", "parent": "110322", "seq": "16", "start_time": "01:59.20", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "42.16", "audio_path": "/qmmp3/18275/110338_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "119.20"}], "start_time_sec": "0.88"}, {"id": "110339", "content": "", "content_zh": "", "words_num": "696", "level": "1", "parent": "110321", "seq": "2", "start_time": "02:41.36", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "126.00", "audio_path": "/qmmp3/18275/110339_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110340", "content": "Peter: Then as I said, we have a programme of events as well, both at the weekend, and during the week.", "content_zh": "彼得：就像我说的，我们在周末和工作日都有活动安排。", "words_num": "21", "level": "2", "parent": "110339", "seq": "1", "start_time": "02:41.36", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.68", "audio_path": "/qmmp3/18275/110340_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "161.36"}, {"id": "110341", "content": "Jan: Right. I presume you have guided walks? I’d like to get to know the local countryside, as I’m new to the area.", "content_zh": "简：是的。我猜你们有导游陪同徒步吧?我想了解一下当地的农村郊野，因为我是新来的。", "words_num": "23", "level": "2", "parent": "110339", "seq": "2", "start_time": "02:47.04", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.00", "audio_path": "/qmmp3/18275/110341_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "167.04"}, {"id": "110342", "content": "Peter: Yes, we do. The next walk is to Ruston Island, a week on Saturday. We’ll be meeting in the car park at Dunsmore Beach at low tide – that’s when the sands are dry enough for us to walk to the island without getting wet.", "content_zh": "彼得：是的，我们有。接下来是去拉斯顿岛，周六出发持续一个星期。我们将在退潮时在邓斯莫尔海滩的停车场见面——那时沙子足够干，我们可以走到岛上而不被弄湿。", "words_num": "46", "level": "2", "parent": "110339", "seq": "3", "start_time": "02:56.04", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "13.68", "audio_path": "/qmmp3/18275/110342_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "176.04"}, {"id": "110343", "content": "Jan: Sounds good.", "content_zh": "简：听起来不错。", "words_num": "3", "level": "2", "parent": "110339", "seq": "4", "start_time": "03:09.72", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "1.40", "audio_path": "/qmmp3/18275/110343_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "189.72"}, {"id": "110344", "content": "Peter: The island’s a great place to explore. It’s quite small, and it’s got a range of habitats. It’s also an ideal location for seeing seals just off the coast, or even on the beach.", "content_zh": "彼得：这座岛是一个值得探索的好地方。它很小，有很多栖息地。它也是一个理想的在海岸，甚至在海滩上看海豹的地点。", "words_num": "35", "level": "2", "parent": "110339", "seq": "5", "start_time": "03:11.12", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "11.64", "audio_path": "/qmmp3/18275/110344_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "191.12"}, {"id": "110345", "content": "Jan: OK. And is there anything we should bring, like a picnic, for instance?", "content_zh": "简：好。有什么要带的吗，比如野餐（食物）之类的?", "words_num": "14", "level": "2", "parent": "110339", "seq": "6", "start_time": "03:22.76", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.44", "audio_path": "/qmmp3/18275/110345_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "202.76"}, {"id": "110346", "content": "Peter: Yes, do bring one, as it’s a full-day walk. And of course it’ll be wet walking across and back, so make sure your boots are waterproof.", "content_zh": "彼得：是的，一定要带一个，因为要走一整天。当然，来回走会很湿，所以确保你的靴子是防水的。", "words_num": "27", "level": "2", "parent": "110339", "seq": "7", "start_time": "03:29.20", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.64", "audio_path": "/qmmp3/18275/110346_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "209.20"}, {"id": "110347", "content": "Jan: I must buy a new pair – there’s a hole in one of my current ones! Well, I’d definitely like to come on the walk.", "content_zh": "简：我必须买双新的，我现在穿的那双有个洞!好吧，我真的非常想来这个徒步。", "words_num": "26", "level": "2", "parent": "110339", "seq": "8", "start_time": "03:38.84", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.44", "audio_path": "/qmmp3/18275/110347_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "218.84"}, {"id": "110348", "content": "Peter: Great. Then later this month we\\\\\\'re having a one-day woodwork session in Hopton Wood.", "content_zh": "彼得：太好了。这个月晚些时候我们会在霍普顿森林举办为期一天的木工课程。", "words_num": "15", "level": "2", "parent": "110339", "seq": "9", "start_time": "03:47.28", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.12", "audio_path": "/qmmp3/18275/110348_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "227.28"}, {"id": "110349", "content": "Jan: I’ve never tried that before. Is it OK for beginners to take part?", "content_zh": "简：我以前从没试过。初学者可以参加吗?", "words_num": "14", "level": "2", "parent": "110339", "seq": "10", "start_time": "03:53.40", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.32", "audio_path": "/qmmp3/18275/110349_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "233.40"}, {"id": "110350", "content": "Peter: Definitely. There’ll be a couple of experts leading the session, and we keep the number of participants down, so you’ll get as much help as you need.", "content_zh": "彼得：当然。会有几位专家主导课程，我们会控制参与者的人数，这样你们就能得到尽可能多的帮助。", "words_num": "28", "level": "2", "parent": "110339", "seq": "11", "start_time": "03:58.72", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.32", "audio_path": "/qmmp3/18275/110350_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "238.72"}, {"id": "110351", "content": "Jan: Excellent! I’d love to be able to make chairs.", "content_zh": "简：太好了!我很想能做些椅子。", "words_num": "10", "level": "2", "parent": "110339", "seq": "12", "start_time": "04:07.04", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "3.92", "audio_path": "/qmmp3/18275/110351_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "247.04"}, {"id": "110352", "content": "Peter: That’s probably too ambitious for one day! You’ll be starting with wooden spoons, and of course learning how to use the tools. And anything you make is yours to take home with you.", "content_zh": "彼得：对于一天的课程来说，可能野心太大了些！你将从木制勺子开始，当然还要学习如何使用这些工具。你做的任何东西都可以带回家。", "words_num": "34", "level": "2", "parent": "110339", "seq": "13", "start_time": "04:10.96", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "11.72", "audio_path": "/qmmp3/18275/110352_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "250.96"}, {"id": "110353", "content": "Jan: That sounds like fun. When is it?", "content_zh": "简：听起来很有趣。它（课程）是什么时候?", "words_num": "8", "level": "2", "parent": "110339", "seq": "14", "start_time": "04:22.68", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "3.32", "audio_path": "/qmmp3/18275/110353_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "262.68"}, {"id": "110354", "content": "Peter: It’s on the 17th, from 10 a.m. until 3. There’s a charge of ￡35, including lunch, or￡40 if you want to camp in the wood.", "content_zh": "彼得：17号，上午10点到3点。费用是35英镑，包括午餐，如果你想在树林里露营，费用是40英镑。", "words_num": "26", "level": "2", "parent": "110339", "seq": "15", "start_time": "04:26.00", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "11.52", "audio_path": "/qmmp3/18275/110354_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "266.00"}, {"id": "110355", "content": "Jan: I should think I’ll come home the same day. Well, I’d certainly like to join the group.", "content_zh": "简：我想我当天就回家。我很想加入这个小组。", "words_num": "18", "level": "2", "parent": "110339", "seq": "16", "start_time": "04:37.52", "created_at": "2024-11-18 17:08:22", "updated_at": "2025-02-25 14:24:38", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.48", "audio_path": "/qmmp3/18275/110355_20250225142433.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "277.52"}], "start_time_sec": "161.36"}]}}}, "relative_seq": ["1", "10"]}], "sectionSheet": {"id": 318, "title": "Buckworth Conservation Group", "category_id": 0, "type": 0, "child_num": 10, "subject": 2, "question": [{"section_id": 318, "qid": 101888, "seq": 1}], "quiz_configs": []}, "logs": [], "explains": {"101889": {"officialExplain": []}, "101890": {"officialExplain": {"id": "10726", "question_id": "101890", "audio_time": null, "explain": "<p>题干词<span lang=\"EN-GB\">beach</span>原词重现，题干中的否定结构<span lang=\"EN-GB\">does not have…</span>在原文中替换为<span lang=\"EN-GB\">free of…</span>，考生需要了解<span lang=\"EN-GB\">free of sth.</span>的意思为“没有<b>……</b>”。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:25:25", "updated_at": "2024-10-18 11:25:25", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101891": {"officialExplain": {"id": "10727", "question_id": "101891", "audio_time": null, "explain": "<p>本题答案前置，先通过提问者说出，再通过回答者所说的<span lang=\"EN-GB\">I’m afraid not</span>对应题干否定词<span lang=\"EN-GB\">no</span>。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:25:36", "updated_at": "2024-10-18 11:25:36", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101892": {"officialExplain": {"id": "10728", "question_id": "101892", "audio_time": null, "explain": "<p>通过题干词<span lang=\"EN-GB\">next</span>预判原文该句应为将来时态，题干中的<span lang=\"EN-GB\">attract</span>对应录音中的<span lang=\"EN-GB\">encourage</span>，之后紧跟答案<span lang=\"EN-GB\">insects</span>，注意填入复数。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:25:50", "updated_at": "2024-10-18 11:25:50", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101893": {"officialExplain": {"id": "10729", "question_id": "101893", "audio_time": null, "explain": "<p>题干词<span lang=\"EN-GB\">identify</span>原词重现，<span lang=\"EN-GB\">types</span>替换为<span lang=\"EN-GB\">species</span>，随后出现答案<span lang=\"EN-GB\">butterflies</span>，注意是复数。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:25:58", "updated_at": "2024-10-18 11:25:58", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101894": {"officialExplain": {"id": "10730", "question_id": "101894", "audio_time": null, "explain": "<p>根据题干可知填入单数名词，<span lang=\"EN-GB\">build</span>和<span lang=\"EN-GB\">new</span>在原文录音中通过<span lang=\"EN-GB\">replace</span>一词体现，随后出现答案<span lang=\"EN-GB\">wall</span>。后文的<span lang=\"EN-GB\">badly damaged in a storm</span>可帮助验证答案。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:26:08", "updated_at": "2024-10-18 11:26:08", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101895": {"officialExplain": {"id": "10731", "question_id": "101895", "audio_time": null, "explain": "<p>根据<span lang=\"EN-GB\">Dunsmore Beach</span>大致定位；随后出现题干词<span lang=\"EN-GB\">sands</span>，简单解释了退潮后开始上岛的原因；紧接着出现了<span lang=\"EN-GB\">walk to…</span>，对应题干中的<span lang=\"EN-GB\">reach</span>，随即出现答案<span lang=\"EN-GB\">island</span>。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:26:16", "updated_at": "2024-10-18 11:26:16", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101896": {"officialExplain": {"id": "10732", "question_id": "101896", "audio_time": null, "explain": "<p>通过<span lang=\"EN-GB\">wear</span>预判所填内容为衣物、鞋子等，需要学生认识<span lang=\"EN-GB\">boots</span>一词。题干中的<span lang=\"EN-GB\">appropriate</span>在录音中替换为更为具体的<span lang=\"EN-GB\">waterproof</span>。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:26:24", "updated_at": "2024-10-18 11:26:24", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101897": {"officialExplain": {"id": "10733", "question_id": "101897", "audio_time": null, "explain": "<p>通过题干可知该题填入<span lang=\"EN-GB\">participate</span>的主语，<span lang=\"EN-GB\">participate</span>在录音中替换为<span lang=\"EN-GB\">take part</span>。<span lang=\"EN-GB\">beginners</span>由提问人说出，再由回答者说出<span lang=\"EN-GB\">definitely</span>予以肯定。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:26:32", "updated_at": "2024-10-18 11:26:32", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101898": {"officialExplain": {"id": "10734", "question_id": "101898", "audio_time": null, "explain": "<p>通过题干可知需要填入木头所制的东西。先由提问者说出<span lang=\"EN-GB\">make chairs</span>，但回答者通过<span lang=\"EN-GB\">too ambitious</span>进行了否定，之后引出答案<span lang=\"EN-GB\">spoons</span>。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:26:40", "updated_at": "2024-10-18 11:26:40", "type": "0", "video_ids": "", "teacher_id": "0"}}, "101899": {"officialExplain": {"id": "10735", "question_id": "101899", "audio_time": null, "explain": "<p>本题需要留意金额，并注意题干中的<span lang=\"EN-GB\">no camping</span>，故<span lang=\"EN-GB\">£35</span>为正确答案。录音中后续提到的<span lang=\"EN-GB\">£40</span>为包含<span lang=\"EN-GB\">camping</span>的价格。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 11:26:49", "updated_at": "2024-10-18 11:26:49", "type": "0", "video_ids": "", "teacher_id": "0"}}}, "quitUrl": "https://ielts.kmf.com/n/practice/listening/order", "superCorrectionInfo": [], "questionMap": [[{"qid": "101889", "parent_qid": "101888", "top_qid": "101888", "level": 2, "seq": 1, "sheet_seq": 1, "subject": 2}]], "restartUrl": "", "relationTask": null, "actionLogs": [], "abilityTestResult": [], "isTeacher": 0}}