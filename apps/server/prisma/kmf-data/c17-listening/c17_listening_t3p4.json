, "source": [], "corpus": [], "audio": [], "relative_seq": ["40"]}], "parent": {"question": {"obj": {"id": "102032", "createTime": "2023-11-14 16:23:09", "lastmodifyTime": "2023-11-14 16:23:09", "creator": "11877510", "type": "393", "level": "0", "subject": "24", "title": "", "title_zh": "", "content": "", "content_zh": "", "parent": "0", "option": "0", "order_index": "3", "seq": "4", "q_cate": "0", "q_cate_sec": "0", "status": "0", "project": "4", "permission": "0", "correct_answer": "0", "is_agree": "0", "business_type": "0", "logic_type": "0", "subjects": null, "business_id": "0", "difficulty_level": "0", "suggested_duration_sec": "0", "input_method": "1", "is_private": "0", "encrypt_id": "e26q8j", "subject_cn": "LISTENING", "subject_zh": "听力", "projectname": "ielts", "html_content": "", "type_cn": "听力祖题目"}}, "answer": [], "option": [], "source": [{"id": "811", "content": "C17", "project": "4", "status": "0", "group_id": "37", "alias_content": "", "sort": "99", "is_hit": "0", "is_new_exam": "0", "hit_month": "0", "qtos_id": "80432", "seq": "0", "set": "0"}], "corpus": [], "audio": [{"id": "18309", "name": "d962bf6f1b296c346c369b11d968af19.mp3", "url": "https://img.kmf.com/ielts/listening/audio/d962bf6f1b296c346c369b11d968af19.mp3", "created_at": "2023-11-14 16:23:09", "updated_at": "2025-02-25 14:51:57", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "0", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "d962bf6f1b296c346c369b11d968af19", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/d962bf6f1b296c346c369b11d968af19.mp3", "picPath": "https://img.kmf.com/ielts/listening-img/0.jpg", "html_content": "", "section_type": "0"}, {"id": "18308", "name": "f5f8312bff944152e516c0f413a84bc6.mp3", "url": "https://img.kmf.com/ielts/listening/audio/f5f8312bff944152e516c0f413a84bc6.mp3", "created_at": "2023-11-14 16:23:09", "updated_at": "2025-02-25 14:51:57", "passport_id": "0", "audio_time": "335.00", "audio_pic": "", "status": "0", "content": "", "type": "1", "content_zh": "", "audio_time_human": "05:35.00", "parentPath": "", "title": "f5f8312bff944152e516c0f413a84bc6", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/f5f8312bff944152e516c0f413a84bc6.mp3", "picPath": "", "html_content": "", "section_type": "0"}, {"id": "18310", "name": "268e0e4b4d196c6ee8279f30f5eca7eb.mp3", "url": "https://img.kmf.com/ielts/listening/audio/268e0e4b4d196c6ee8279f30f5eca7eb.mp3", "created_at": "2023-11-14 16:23:09", "updated_at": "2025-02-25 14:51:57", "passport_id": "0", "audio_time": "0", "audio_pic": "", "status": "0", "content": "", "type": "2", "content_zh": "", "audio_time_human": "0", "parentPath": "", "title": "268e0e4b4d196c6ee8279f30f5eca7eb", "formatType": "mp3", "filePath": "https://img.kmf.com/ielts/listening/audio/268e0e4b4d196c6ee8279f30f5eca7eb.mp3", "picPath": "", "html_content": "", "section_type": "0"}], "lyric": {"18308": {"id": "110767", "content": "", "content_zh": "", "words_num": "0", "level": "0", "parent": "0", "seq": "0", "start_time": "", "created_at": "2024-11-20 17:16:16", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "335.00", "audio_path": "", "listen_num": "0", "listen_people": "0", "start_time_sec": "", "section": [{"id": "110768", "content": "", "content_zh": "", "words_num": "706", "level": "1", "parent": "110767", "seq": "1", "start_time": "00:00.24", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "178.92", "audio_path": "/qmmp3/18308/110768_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110769", "content": "Scientists believe that a majority of the earth’s bird population migrate in some fashion or other.", "content_zh": "科学家认为，地球上的大多数鸟类都以这样或那样的方式迁徙。", "words_num": "16", "level": "2", "parent": "110768", "seq": "1", "start_time": "00:00.24", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.80", "audio_path": "/qmmp3/18308/110769_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "0.24"}, {"id": "110770", "content": "Some travel seasonally for relatively short distances, such as birds that move from their winter habitats in lowlands to mountain tops for the summers.", "content_zh": "有些是季节性迁徙，距离相对较短，比如鸟类从它们冬季的低地栖息地迁徙到夏季的山顶。", "words_num": "24", "level": "2", "parent": "110768", "seq": "2", "start_time": "00:08.04", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.92", "audio_path": "/qmmp3/18308/110770_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "8.04"}, {"id": "110771", "content": "Others, like the Arctic Tern, travel more than 25,000 miles seasonally between the northern and southern poles.", "content_zh": "其他的，比如北极燕鸥，季节性地在南北两极之间旅行超过25000英里。", "words_num": "17", "level": "2", "parent": "110768", "seq": "3", "start_time": "00:18.96", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.92", "audio_path": "/qmmp3/18308/110771_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "18.96"}, {"id": "110772", "content": "Bird migration has been studied over many centuries through a variety of observations.", "content_zh": "几个世纪以来，人们通过各种观察对鸟类迁徙进行了研究。", "words_num": "13", "level": "2", "parent": "110768", "seq": "4", "start_time": "00:29.88", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "6.12", "audio_path": "/qmmp3/18308/110772_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "29.88"}, {"id": "110773", "content": "But until relatively recently, where birds went to in the winter was considered something of a mystery.", "content_zh": "但直到最近，鸟类在冬天去哪里还被认为是一个谜。", "words_num": "17", "level": "2", "parent": "110768", "seq": "5", "start_time": "00:36.00", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "7.52", "audio_path": "/qmmp3/18308/110773_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "36.00"}, {"id": "110774", "content": "The lack of modern science and technology led to many theories that we now recognize as error-filled and even somewhat amusing.", "content_zh": "现代科学技术的缺乏导致了许多我们现在认为充满错误甚至有些可笑的理论的存在。", "words_num": "21", "level": "2", "parent": "110768", "seq": "6", "start_time": "00:43.52", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.56", "audio_path": "/qmmp3/18308/110774_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "43.52"}, {"id": "110775", "content": "Take hibernation theory for example – two thousand years ago, it was commonly believed that when birds left an area, they went underwater to hibernate in the seas and oceans.", "content_zh": "以冬眠理论为例，两千年前人们普遍相信，当鸟儿离开一个区域，它们会在海洋里冬眠。", "words_num": "30", "level": "2", "parent": "110768", "seq": "7", "start_time": "00:54.08", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "14.48", "audio_path": "/qmmp3/18308/110775_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "54.08"}, {"id": "110776", "content": "Another theory for the regular appearance and disappearance of birds was that they spent winter hidden in mud till the weather changed and food became abundant again.", "content_zh": "关于鸟儿有规律的出现或消失，还有另一个理论：鸟儿会藏在泥里过冬，直到天气变暖且食物再次变得充裕。", "words_num": "27", "level": "2", "parent": "110768", "seq": "8", "start_time": "01:08.56", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "12.32", "audio_path": "/qmmp3/18308/110776_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "68.56"}, {"id": "110777", "content": "The theory that some birds hibernate persisted until experiments were done on caged birds in the 1940s which demonstrated that birds have no hibernation instinct.", "content_zh": "鸟类冬眠的理论一直存在，直到20世纪40年代在笼子里做的实验证明鸟类没有冬眠的本能。", "words_num": "25", "level": "2", "parent": "110768", "seq": "9", "start_time": "01:20.88", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "13.80", "audio_path": "/qmmp3/18308/110777_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "80.88"}, {"id": "110778", "content": "One of the earliest naturalists and philosophers from ancient Greece was Aristotle who was the first writer to discuss the disappearance and reappearance of some bird species at certain times of year.", "content_zh": "古希腊最早的博物学家和哲学家之一是亚里士多德，他是第一个讨论一些鸟类在一年中的特定时间消失和重新出现的作家。", "words_num": "32", "level": "2", "parent": "110768", "seq": "10", "start_time": "01:34.68", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "15.40", "audio_path": "/qmmp3/18308/110778_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "94.68"}, {"id": "110779", "content": "He developed the theory of transmutation, the seasonal change of one species into another, by observing redstarts and robins.", "content_zh": "亚里士多德通过观察红尾鸲和知更鸟，提出了演变理论，认为这些鸟会季节性地转换成其他物种。", "words_num": "19", "level": "2", "parent": "110768", "seq": "11", "start_time": "01:50.08", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.20", "audio_path": "/qmmp3/18308/110779_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "110.08"}, {"id": "110780", "content": "He observed that in the autumn, small birds called ‘redstarts’ began to lose their feathers, which convinced Aristotle that they changed into robins for the winter, and back into redstarts in the summer.", "content_zh": "这让亚里士多德相信这种鸟儿在冬天的时候会变成知更鸟，在夏天时则会变回来。", "words_num": "33", "level": "2", "parent": "110768", "seq": "12", "start_time": "02:00.28", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "15.56", "audio_path": "/qmmp3/18308/110780_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "120.28"}, {"id": "110781", "content": "These assumptions are understandable given that this pair of species are similar in shape, but are a classic example of an incorrect interpretation based on correct observations.", "content_zh": "鉴于这一组鸟类在体型上接近，所以这些假设可以理解。但是，这是基于正确观察得出的错误解读的典型案例。", "words_num": "27", "level": "2", "parent": "110768", "seq": "13", "start_time": "02:15.84", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "14.44", "audio_path": "/qmmp3/18308/110781_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "135.84"}, {"id": "110782", "content": "The most bizarre theory was put forward by an English amateur scientist, Charles Morton, in the seventeenth century.", "content_zh": "最奇异的理论是由英国业余科学家查尔斯·莫顿在17世纪提出的。", "words_num": "18", "level": "2", "parent": "110768", "seq": "14", "start_time": "02:30.28", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.68", "audio_path": "/qmmp3/18308/110782_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "150.28"}, {"id": "110783", "content": "He wrote a surprisingly well-regarded paper claiming that birds migrate to the moon and back every year.", "content_zh": "他写了一篇关于鸟儿每年会迁徙去月球再返回地球的论文。这篇论文大获好评。", "words_num": "17", "level": "2", "parent": "110768", "seq": "15", "start_time": "02:38.96", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.28", "audio_path": "/qmmp3/18308/110783_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "158.96"}, {"id": "110784", "content": "He came to this conclusion as the only logical explanation for the total disappearance of some species.", "content_zh": "他得出这个结论，认为这是某些物种完全消失的唯一合乎逻辑的解释。", "words_num": "17", "level": "2", "parent": "110768", "seq": "16", "start_time": "02:47.24", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "11.92", "audio_path": "/qmmp3/18308/110784_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "167.24"}], "start_time_sec": "0.24"}, {"id": "110785", "content": "", "content_zh": "", "words_num": "648", "level": "1", "parent": "110767", "seq": "2", "start_time": "02:59.16", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "156.00", "audio_path": "/qmmp3/18308/110785_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "sentence": [{"id": "110786", "content": "One of the key moments in the development of migration theory came in 1822 when a white stork was shot in Germany.", "content_zh": "迁徙理论发展的关键时刻之一发生在1822年，当时一只白鹳在德国被射杀，这只特殊的鹳创造了历史。", "words_num": "22", "level": "2", "parent": "110785", "seq": "1", "start_time": "02:59.16", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.64", "audio_path": "/qmmp3/18308/110786_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "179.16"}, {"id": "110787", "content": "This particular stork made history because of the long spear in its neck which incredibly had not killed it – everyone immediately realised this spear was definitely not European.", "content_zh": "一根长矛刺穿了它的脖子却没有杀死它。人们立即意识到这长矛肯定不属于欧洲。", "words_num": "29", "level": "2", "parent": "110785", "seq": "2", "start_time": "03:09.80", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "15.04", "audio_path": "/qmmp3/18308/110787_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "189.80"}, {"id": "110788", "content": "It turned out to be a spear from a tribe in Central Africa.", "content_zh": "结果证明，这根矛来自非洲中部的一个部落。", "words_num": "13", "level": "2", "parent": "110785", "seq": "3", "start_time": "03:24.84", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "4.72", "audio_path": "/qmmp3/18308/110788_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "204.84"}, {"id": "110789", "content": "This was a truly defining moment in the history of ornithology because it was the first evidence that storks spend their winters in sub-Saharan Africa.", "content_zh": "这是鸟类学研究史上决定性的一刻，因为（人们）第一次持有了鹳在非洲撒哈拉沙漠以南的地区过冬的证据。", "words_num": "25", "level": "2", "parent": "110785", "seq": "4", "start_time": "03:29.56", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "12.40", "audio_path": "/qmmp3/18308/110789_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "209.56"}, {"id": "110790", "content": "You can still see the ‘arrow stork’ in the Zoological Collection of the University of Rostock in Germany.", "content_zh": "你仍然可以在德国罗斯托克大学的动物收藏中看到这只“箭鹳”。", "words_num": "18", "level": "2", "parent": "110785", "seq": "5", "start_time": "03:41.96", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.36", "audio_path": "/qmmp3/18308/110790_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "221.96"}, {"id": "110791", "content": "People gradually became aware that European birds moved south in autumn and north in summer but didn’t know much about it until the practice of catching birds and putting rings on their legs became established.", "content_zh": "人们逐渐意识到，欧洲的鸟儿秋天往南飞，夏天往北飞，但是不甚了解，直到抓取鸟儿后给鸟儿带上脚环变成一种惯例。", "words_num": "35", "level": "2", "parent": "110785", "seq": "6", "start_time": "03:51.32", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "14.92", "audio_path": "/qmmp3/18308/110791_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "231.32"}, {"id": "110792", "content": "Before this, very little information was available about the actual destinations of particular species and how they travelled there.", "content_zh": "在此之前，人们并不清楚某一特定物种准确的迁徙目的地，以及它们是如何去到那儿的。", "words_num": "19", "level": "2", "parent": "110785", "seq": "7", "start_time": "04:06.24", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.88", "audio_path": "/qmmp3/18308/110792_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "246.24"}, {"id": "110793", "content": "People speculated that larger birds provided a kind of taxi service for smaller birds by carrying them on their backs.", "content_zh": "人们推测，体型较大的鸟类为体型较小的鸟类提供了一种出租车服务，它们把体型较小的鸟类背在背上。", "words_num": "20", "level": "2", "parent": "110785", "seq": "8", "start_time": "04:16.12", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.08", "audio_path": "/qmmp3/18308/110793_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "256.12"}, {"id": "110794", "content": "This idea came about because it seemed impossible that small birds weighing only a few grams could fly over vast oceans.", "content_zh": "这个想法的产生是因为体重只有几克的小鸟似乎不可能飞越浩瀚的海洋。", "words_num": "21", "level": "2", "parent": "110785", "seq": "9", "start_time": "04:25.20", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "9.96", "audio_path": "/qmmp3/18308/110794_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "265.20"}, {"id": "110795", "content": "This idea was supported by observations of bird behaviour such as the harassment of larger birds by smaller birds.", "content_zh": "这一观点得到了对鸟类行为的观察的支持，例如大型鸟类受到小型鸟类的骚扰。", "words_num": "19", "level": "2", "parent": "110785", "seq": "10", "start_time": "04:35.16", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.32", "audio_path": "/qmmp3/18308/110795_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "275.16"}, {"id": "110796", "content": "The development of bird ringing, by a Danish schoolteacher, Hans Christian Cornelius Mortensen, made many discoveries possible.", "content_zh": "由丹麦教师Hans Christian Cornelius Mortensen发起的鸟类环志让许多发现变得可能。", "words_num": "17", "level": "2", "parent": "110785", "seq": "11", "start_time": "04:45.48", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "10.08", "audio_path": "/qmmp3/18308/110796_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "285.48"}, {"id": "110797", "content": "This is still common practice today and relies upon what is known as ‘recovery’ – this is when ringed birds are found dead in the place they have migrated to, and identified.", "content_zh": "鸟类环志依然是今天常见的惯例，依赖于找回，即被套上脚环的鸟儿死去之后，人们在它迁居之地找到并且识别它。", "words_num": "32", "level": "2", "parent": "110785", "seq": "12", "start_time": "04:55.56", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "13.56", "audio_path": "/qmmp3/18308/110797_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "295.56"}, {"id": "110798", "content": "Huge amounts of data were gathered in the early part of the twentieth century and for the first time in history people understood where birds actually went to in winter.", "content_zh": "在20世纪早期，人们收集了大量的数据，这是历史上第一次，人们了解到了鸟类在冬天到底去了哪里。", "words_num": "30", "level": "2", "parent": "110785", "seq": "13", "start_time": "05:09.12", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "12.08", "audio_path": "/qmmp3/18308/110798_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "309.12"}, {"id": "110799", "content": "In 1931, an atlas was published showing where the most common species of European birds migrated to.", "content_zh": "在1931年，一份印有欧洲寻常鸟类迁徙去向何处的地图集出版了。", "words_num": "17", "level": "2", "parent": "110785", "seq": "14", "start_time": "05:21.20", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "8.32", "audio_path": "/qmmp3/18308/110799_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "321.20"}, {"id": "110800", "content": "More recent theories about bird migration …", "content_zh": "更多近期关于鸟类迁徙的理论……", "words_num": "7", "level": "2", "parent": "110785", "seq": "15", "start_time": "05:29.52", "created_at": "2024-11-20 17:16:17", "updated_at": "2025-02-25 14:52:17", "passport_id": "11877510", "status": "0", "collect_num": "0", "audio_time": "5.48", "audio_path": "/qmmp3/18308/110800_20250225145212.mp3", "listen_num": "0", "listen_people": "0", "start_time_sec": "329.52"}], "start_time_sec": "179.16"}]}}}, "relative_seq": ["31", "40"]}], "sectionSheet": {"id": 358, "title": "Bird Migration Theory", "category_id": 0, "type": 0, "child_num": 10, "subject": 2, "question": [{"section_id": 358, "qid": 102032, "seq": 1}], "quiz_configs": []}, "logs": [], "explains": {"102033": {"officialExplain": []}, "102044": {"officialExplain": {"id": "10810", "question_id": "102044", "audio_time": null, "explain": "<p>本题可通过Hibernation theory定位，根据语法预测，空内填写名词，题干词buried与原文hidden替换，随机出现答案mud。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:00:17", "updated_at": "2024-10-18 18:00:17", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102034": {"officialExplain": {"id": "10811", "question_id": "102034", "audio_time": null, "explain": "<p>题干词autumn原文重现，可以帮助定位。由题干语法判断需要定位名词，题干词loss在原文中以lose形式出现，随即出现答案词feathers。考生应注意此处需要加s。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:00:39", "updated_at": "2024-10-18 18:00:39", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102036": {"officialExplain": {"id": "10812", "question_id": "102036", "audio_time": null, "explain": "<p>题干词assumption原文重现，可以帮助定位。题干词logical与原文understandable替换，题干词similar原文重现，后面正好接了答案shape。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:01:01", "updated_at": "2024-10-18 18:01:01", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102037": {"officialExplain": {"id": "10813", "question_id": "102037", "audio_time": null, "explain": "<p>本题依靠Charles Morton定位，题干词fly与原文migrate替换。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:01:22", "updated_at": "2024-10-18 18:01:22", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102038": {"officialExplain": {"id": "10814", "question_id": "102038", "audio_time": null, "explain": "<p>本题可用1822或者Germany定位，题干词killed与原文shot替换。答案句翻译请见文件解析第5句。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:01:42", "updated_at": "2024-10-18 18:01:42", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102039": {"officialExplain": {"id": "10815", "question_id": "102039", "audio_time": null, "explain": "<p>本题无明确定位词，需要在上题结束后耐心等待，根据语法可知空内填写名词。题干词previously… no…与原文 It was the first…替换。答案句翻译请见文件解析第6句。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:02:03", "updated_at": "2024-10-18 18:02:03", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102040": {"officialExplain": {"id": "10816", "question_id": "102040", "audio_time": null, "explain": "<p>本题无明确定位词，需要在上题结束后耐心等待，根据语法可知空内填写名词。题干词little was known与原文very little information替换，题干词journey与原文how they travelled there替换。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:02:30", "updated_at": "2024-10-18 18:02:30", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102041": {"officialExplain": {"id": "10817", "question_id": "102041", "audio_time": null, "explain": "<p>本题无明确定位词，需要在上题结束后耐心等待，根据语法可知空内填写名词。题干词large birds carried small birds与原文taxi service替换，incapable与impossible替换，across与 fly over替换，后接答案oceans。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:03:03", "updated_at": "2024-10-18 18:03:03", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102042": {"officialExplain": {"id": "10818", "question_id": "102042", "audio_time": null, "explain": "<p>题干词ringing原文重现，定位难度低。题干词what is called与原文 what is known as替换，后接答案recovery。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:03:25", "updated_at": "2024-10-18 18:03:25", "type": "0", "video_ids": "", "teacher_id": "0"}}, "102043": {"officialExplain": {"id": "10819", "question_id": "102043", "audio_time": null, "explain": "<p>题干词1931原文重现，定位难度低。题干词printed与原文published替换，答案为atlas，意为地图集。考生需掌握单词atlas，同时听音反应速度要快，方可写对。<br></p>", "subject": "24", "praise_num": "0", "step_num": "0", "created_at": "2024-10-18 18:03:45", "updated_at": "2024-10-18 18:03:45", "type": "0", "video_ids": "", "teacher_id": "0"}}}, "quitUrl": "https://ielts.kmf.com/n/practice/listening/order", "superCorrectionInfo": [], "questionMap": [[{"qid": "102033", "parent_qid": "102032", "top_qid": "102032", "level": 2, "seq": 1, "sheet_seq": 1, "subject": 2}]], "restartUrl": "", "relationTask": null, "actionLogs": [], "abilityTestResult": [], "isTeacher": 0}}