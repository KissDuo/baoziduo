acher_id":"0"}},"112912":{"officialExplain":{"id":"15490","question_id":"112912","audio_time":null,"explain":"<p>\u6839\u636e\u9898\u5e72\u7684\u5bbe\u8bedher\u53ef\u77e5\u9700\u8981\u586b\u5165\u52a8\u8bcd\uff0c\u800c\u548c\u4e0b\u4e00\u9898\u9898\u5e72\u7684preventing\u6bd4\u5bf9\u53ef\u77e5\uff0c\u5f88\u53ef\u80fd\u586b\u5165\u52a8\u540d\u8bcd\u5f62\u5f0f\u3002\u4e0a\u4e00\u9898\u8c08\u8bbamemory\u7ed3\u675f\u540e\uff0c\u7537\u58eb\u95ee\u201cAnd are there any physical difficulties you have caring for her?\u201d\uff0c\u63d0\u793a\u672c\u9898\u5373\u5c06\u51fa\u73b0\u3002\u5e76\u4e14\u4e0b\u4e00\u53e5\u7537\u58eb\u5c31\u4ee5\u8be2\u95ee\u7684\u5f62\u5f0f\u8bf4\u51fa\u4e86\u7b54\u6848lifting\uff0c\u968f\u540e\u5973\u58eb\u7ed9\u4e86\u80af\u5b9a\u7684\u56de\u7b54\u3002\u8003\u751f\u9700\u8981\u63d0\u524d\u505a\u597d\u8bcd\u6027\u9884\u5224\uff0c\u5e76\u5728\u7537\u58eb\u63d0\u51fa\u8be2\u95ee\u65f6\u5c31\u7559\u610f\u7b54\u6848\u3002<\/p>","subject":"24","praise_num":"0","step_num":"0","created_at":"2025-08-08 11:54:35","updated_at":"2025-08-08 11:54:35","type":"0","video_ids":"","teacher_id":"0"}},"112913":{"officialExplain":{"id":"15491","question_id":"112913","audio_time":null,"explain":"<p>\u539f\u6587\u8ba8\u8bbalifting her\u4e4b\u540e\u901a\u8fc7and also\u5f15\u51fa\u4e0b\u4e00\u9898\uff0cpreventing\u66ff\u6362\u4e3aavoid\uff0c\u968f\u540e\u51fa\u73b0\u7b54\u6848fall\u3002<\/p>","subject":"24","praise_num":"0","step_num":"0","created_at":"2025-08-08 11:54:51","updated_at":"2025-08-08 11:54:51","type":"0","video_ids":"","teacher_id":"0"}},"112914":{"officialExplain":{"id":"15492","question_id":"112914","audio_time":null,"explain":"<p>\u9898\u5e72\u4e2d\u7684transport costs\u539f\u8bcd\u91cd\u73b0\uff0ce.g.\u66ff\u6362\u4e3alike\uff0c\u968f\u540e\u51fa\u73b0\u7b54\u6848taxi\u3002<\/p>","subject":"24","praise_num":"0","step_num":"0","created_at":"2025-08-08 11:55:08","updated_at":"2025-08-08 11:55:08","type":"0","video_ids":"","teacher_id":"0"}},"112915":{"offici